<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane maxHeight="Infinity"
            maxWidth="Infinity"
            fx:id="gameRoot"
            styleClass="tetris-game-root"
            xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="seda_project.control_alt_defeat.gamebox.controller.tetris.TetrisGameController">

    <stylesheets>
        <URL value="@TetrisMenu.css"/>
    </stylesheets>

    <center>
        <ScrollPane fitToHeight="true"
                    fitToWidth="true"
                    hbarPolicy="AS_NEEDED"
                    vbarPolicy="AS_NEEDED"
                    styleClass="app-scroll">
        <GridPane minHeight="640"
                  minWidth="0"
                  maxHeight="Infinity"
                  maxWidth="Infinity"
                  styleClass="tetris-game-main">
            <columnConstraints>
                <ColumnConstraints hgrow="ALWAYS" percentWidth="60"/>
                <ColumnConstraints hgrow="ALWAYS" percentWidth="40"/>
            </columnConstraints>

            <StackPane GridPane.columnIndex="0"
                       GridPane.hgrow="ALWAYS"
                       GridPane.vgrow="ALWAYS"
                       maxHeight="Infinity"
                       maxWidth="Infinity"
                       styleClass="tetris-board-zone">
                <VBox alignment="CENTER" fillWidth="false" styleClass="boards-stack">
                    <GridPane fx:id="topBoardGrid" rotate="180" styleClass="tetris-board"/>
                    <GridPane fx:id="bottomBoardGrid" styleClass="tetris-board"/>
                </VBox>
            </StackPane>

            <ScrollPane GridPane.columnIndex="1"
                        GridPane.hgrow="ALWAYS"
                        GridPane.vgrow="ALWAYS"
                        fitToHeight="true"
                        fitToWidth="true"
                        hbarPolicy="NEVER"
                        vbarPolicy="AS_NEEDED"
                        maxHeight="Infinity"
                        maxWidth="Infinity"
                        styleClass="app-scroll">
                <VBox maxHeight="Infinity"
                      maxWidth="Infinity"
                      spacing="18"
                      styleClass="tetris-game-info-panel">

                <VBox styleClass="game-sidebar-header">
                    <Label text="Zetris" styleClass="game-side-title"/>
                    <Label fx:id="configLabel" text="Pieces: Standard" styleClass="subtitle"/>
                    <Label fx:id="resultLabel" text="Game running." styleClass="status-line" wrapText="true"/>
                </VBox>

                <Separator styleClass="game-separator"/>

                <VBox spacing="10" styleClass="score-section">
                    <Label text="Points" styleClass="field-title"/>

                    <HBox alignment="CENTER_LEFT" spacing="12">
                        <VBox maxWidth="Infinity" spacing="6" styleClass="player-score-card" HBox.hgrow="ALWAYS">
                            <Label fx:id="topScoreLabel"
                                   text="The Outer God: 0"
                                   minHeight="24"
                                   maxWidth="Infinity"
                                   styleClass="score-label"
                                   style="-fx-text-fill: #7A4A00; -fx-font-weight: 900;"/>
                        </VBox>

                        <VBox maxWidth="Infinity" spacing="6" styleClass="player-score-card" HBox.hgrow="ALWAYS">
                            <Label fx:id="bottomScoreLabel"
                                   text="The Old Monk: 0"
                                   minHeight="24"
                                   maxWidth="Infinity"
                                   styleClass="score-label"
                                   style="-fx-text-fill: #0A235A; -fx-font-weight: 900;"/>
                        </VBox>
                    </HBox>
                </VBox>

                <Separator styleClass="game-separator"/>

                <VBox styleClass="keymap-block">
                    <Label fx:id="keymapTitleLabel" text="Controls" styleClass="field-title"/>
                    <Label fx:id="keymapLabel" text="" styleClass="keymap-label" wrapText="true"/>
                </VBox>

                <Separator styleClass="game-separator"/>

                <VBox spacing="10" VBox.vgrow="ALWAYS">
                    <Label text="Special Objects" styleClass="field-title"/>

                    <ScrollPane fitToWidth="true"
                                hbarPolicy="NEVER"
                                maxHeight="Infinity"
                                maxWidth="Infinity"
                                VBox.vgrow="ALWAYS"
                                styleClass="object-scroll">
                        <content>
                            <GridPane styleClass="object-legend-grid">
                                <columnConstraints>
                                    <ColumnConstraints minWidth="24" prefWidth="24"/>
                                    <ColumnConstraints hgrow="ALWAYS"/>
                                </columnConstraints>

                                <Label text="+" styleClass="object-symbol" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                                <Label text="Opponent 2x faster (10s)" styleClass="object-description" wrapText="true"
                                       GridPane.columnIndex="1" GridPane.rowIndex="0"/>

                                <Label text="-" styleClass="object-symbol" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                                <Label text="You 2x slower (10s)" styleClass="object-description" wrapText="true"
                                       GridPane.columnIndex="1" GridPane.rowIndex="1"/>

                                <Label text="R" styleClass="object-symbol" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
                                <Label text="Opponent rotation lags 2s per press (10s)" styleClass="object-description" wrapText="true"
                                       GridPane.columnIndex="1" GridPane.rowIndex="2"/>

                                <Label text="r" styleClass="object-symbol" GridPane.columnIndex="0" GridPane.rowIndex="3"/>
                                <Label text="Your rotation lags 2s per press (10s)" styleClass="object-description" wrapText="true"
                                       GridPane.columnIndex="1" GridPane.rowIndex="3"/>

                                <Label text="S" styleClass="object-symbol" GridPane.columnIndex="0" GridPane.rowIndex="4"/>
                                <Label text="Opponent 2x slower (10s)" styleClass="object-description" wrapText="true"
                                       GridPane.columnIndex="1" GridPane.rowIndex="4"/>

                                <Label text="*" styleClass="object-symbol" GridPane.columnIndex="0" GridPane.rowIndex="5"/>
                                <Label text="Radius bomb: clears nearby blocks within 3 cells" styleClass="object-description" wrapText="true"
                                       GridPane.columnIndex="1" GridPane.rowIndex="5"/>

                                <Label text="v" styleClass="object-symbol" GridPane.columnIndex="0" GridPane.rowIndex="6"/>
                                <Label text="Column bomb: clears along your gravity direction" styleClass="object-description" wrapText="true"
                                       GridPane.columnIndex="1" GridPane.rowIndex="6"/>

                                <Label text="P" styleClass="object-symbol" GridPane.columnIndex="0" GridPane.rowIndex="7"/>
                                <Label text="Teleport: sends your falling piece to the opponent next" styleClass="object-description" wrapText="true"
                                       GridPane.columnIndex="1" GridPane.rowIndex="7"/>

                                <Label text="T" styleClass="object-symbol" GridPane.columnIndex="0" GridPane.rowIndex="8"/>
                                <Label text="Board swap: swaps boards only" styleClass="object-description" wrapText="true"
                                       GridPane.columnIndex="1" GridPane.rowIndex="8"/>

                                <Label text="G" styleClass="object-symbol" GridPane.columnIndex="0" GridPane.rowIndex="9"/>
                                <Label text="Swap falling pieces only" styleClass="object-description" wrapText="true"
                                       GridPane.columnIndex="1" GridPane.rowIndex="9"/>
                            </GridPane>
                        </content>
                    </ScrollPane>
                </VBox>

                <Separator styleClass="game-separator"/>

                <HBox styleClass="game-actions">
                    <Button fx:id="restartButton" text="Restart" onAction="#onRestart"
                            visible="false" managed="false" maxWidth="Infinity"
                            styleClass="btn-outline" HBox.hgrow="ALWAYS"/>
                    <Button text="Quit to Menu" onAction="#onBackToMenu" maxWidth="Infinity"
                            styleClass="btn-primary" HBox.hgrow="ALWAYS"/>
                </HBox>
                </VBox>
            </ScrollPane>
        </GridPane>
        </ScrollPane>
    </center>
</BorderPane>
