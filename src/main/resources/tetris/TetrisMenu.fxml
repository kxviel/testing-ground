<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox alignment="CENTER"
      spacing="18"
      maxHeight="Infinity"
      maxWidth="Infinity"
      styleClass="tetris-menu-root"
      xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="seda_project.control_alt_defeat.gamebox.controller.tetris.TetrisMenuController">

    <stylesheets>
        <URL value="@TetrisMenu.css"/>
    </stylesheets>

    <padding>
        <Insets top="40" right="56" bottom="40" left="56"/>
    </padding>

    <Label text="Zetris" styleClass="title"/>
    <Label text="Set up a local or LAN match" styleClass="subtitle"/>

    <StackPane fx:id="contentStack" maxWidth="560" minHeight="280" styleClass="menu-panel">
        <VBox fx:id="modeChoicePane" alignment="CENTER" spacing="16">
            <Label text="Choose Match Type" styleClass="section-title"/>
            <HBox alignment="CENTER" spacing="12" styleClass="button-row">
                <Button fx:id="localModeButton" text="Local" onAction="#onLocalMode" styleClass="btn-outline"/>
                <Button fx:id="lanModeButton" text="LAN" onAction="#onLanMode" styleClass="btn-outline"/>
            </HBox>
        </VBox>

        <VBox fx:id="localPane" alignment="CENTER" spacing="16" visible="false" managed="false">
            <Label text="Local Mode - Same Device" styleClass="section-title"/>

            <GridPane alignment="CENTER" hgap="12" vgap="12">
                <columnConstraints>
                    <ColumnConstraints halignment="RIGHT"/>
                    <ColumnConstraints hgrow="ALWAYS" minWidth="220"/>
                </columnConstraints>

                <Label text="Player 1 Name" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                <TextField fx:id="localPlayerOneField" text="Player 1" promptText="Player 1"
                           GridPane.columnIndex="1" GridPane.rowIndex="0"/>

                <Label text="Player 2 Name" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                <TextField fx:id="localPlayerTwoField" text="Player 2" promptText="Player 2"
                           GridPane.columnIndex="1" GridPane.rowIndex="1"/>
            </GridPane>

        </VBox>

        <VBox fx:id="lanPane" alignment="CENTER" spacing="16" visible="false" managed="false">
            <Label text="LAN Mode - Network Play" styleClass="section-title"/>

            <VBox alignment="CENTER" spacing="10">
                <Label text="Choose your Role" styleClass="field-title"/>
                <HBox alignment="CENTER" spacing="12" styleClass="button-row">
                    <Button fx:id="hostRoleButton" text="Host" onAction="#onHostRole" styleClass="btn-outline"/>
                    <Button fx:id="joinRoleButton" text="Join" onAction="#onJoinRole" styleClass="btn-outline"/>
                </HBox>
            </VBox>
        </VBox>

        <VBox fx:id="hostPane" alignment="CENTER" spacing="16" visible="false" managed="false">
            <Label text="LAN Mode - Host Network Play" styleClass="section-title"/>

            <GridPane alignment="CENTER" hgap="12" vgap="12">
                <columnConstraints>
                    <ColumnConstraints halignment="RIGHT"/>
                    <ColumnConstraints hgrow="ALWAYS" minWidth="220"/>
                </columnConstraints>

                <Label text="Enter Your Name" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                <TextField fx:id="hostPlayerNameField" text="Host Player" promptText="Host name"
                           GridPane.columnIndex="1" GridPane.rowIndex="0"/>
            </GridPane>

            <Separator/>

            <Label fx:id="hostInfoLabel" text="Not advertising." styleClass="status-line"/>
            <Label fx:id="joinedPlayerLabel" text="Joined: none" styleClass="status-line"/>
            <Button fx:id="hostStartGameButton" text="Start Game" onAction="#onHostStartGame"
                    disable="true" visible="false" managed="false" styleClass="btn-primary"/>
        </VBox>

        <VBox fx:id="joinPane" alignment="CENTER" spacing="16" visible="false" managed="false">
            <Label text="LAN Mode - Join Network Play" styleClass="section-title"/>

            <GridPane alignment="CENTER" hgap="12" vgap="12">
                <columnConstraints>
                    <ColumnConstraints halignment="RIGHT"/>
                    <ColumnConstraints hgrow="ALWAYS" minWidth="220"/>
                </columnConstraints>

                <Label text="Enter Your Name" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                <TextField fx:id="joinPlayerNameField" text="Joining Player" promptText="Your name"
                           GridPane.columnIndex="1" GridPane.rowIndex="0"/>
            </GridPane>

            <Separator/>

            <Label text="Available Games" styleClass="field-title"/>
            <ListView fx:id="availableGamesList" prefHeight="96" maxWidth="360" onMouseClicked="#onGameSelected"/>
            <Button text="Refresh Games" onAction="#onRefreshGames" styleClass="btn-outline"/>
        </VBox>
    </StackPane>

    <VBox fx:id="configBox" alignment="CENTER" spacing="8" visible="false" managed="false">
        <Label text="Pieces" styleClass="field-title"/>
        <HBox alignment="CENTER" spacing="12">
            <CheckBox fx:id="standardPieceCheckBox" text="Standard" selected="true"/>
            <CheckBox fx:id="extendedPieceCheckBox" text="Extended"/>
            <CheckBox fx:id="customPieceCheckBox" text="Custom" onAction="#onCustomPieceToggle"/>
        </HBox>
        <VBox fx:id="customEditorBox" alignment="CENTER" spacing="8" visible="false" managed="false">
            <Label text="Custom Piece" styleClass="field-title"/>
            <GridPane fx:id="customPieceGrid" alignment="CENTER" styleClass="custom-piece-grid"/>
            <HBox alignment="CENTER" spacing="8">
                <Button text="Clear" onAction="#onClearCustomPiece" styleClass="btn-outline"/>
                <Button text="Save" onAction="#onSaveCustomPiece" styleClass="btn-primary"/>
            </HBox>
            <Label fx:id="customPieceStatusLabel" text="" maxWidth="360" wrapText="true" styleClass="status-line"/>
        </VBox>
    </VBox>

    <Label fx:id="statusLabel" text="" maxWidth="560" wrapText="true" styleClass="status-line"/>

    <HBox alignment="CENTER" spacing="12" styleClass="button-row">
        <Button text="Back" onAction="#onBack" styleClass="btn-outline"/>
        <Button fx:id="startButton" text="Start" onAction="#onStart" styleClass="btn-primary"/>
    </HBox>
</VBox>
