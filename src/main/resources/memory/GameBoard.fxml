<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<BorderPane maxHeight="Infinity"
            maxWidth="Infinity"
            prefHeight="720.0"
            prefWidth="1080.0"
            styleClass="memory-game-root"
            xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="seda_project.control_alt_defeat.gamebox.controller.memory.GameController">
    <stylesheets>
        <URL value="@Memory.css"/>
    </stylesheets>

    <top>
        <HBox alignment="CENTER" spacing="24" styleClass="memory-game-header">
            <HBox fx:id="p1Chip" alignment="CENTER" spacing="16" styleClass="player-chip">
                <StackPane styleClass="player-icon">
                    <Label text="P" styleClass="player-icon-text"/>
                </StackPane>
                <Label fx:id="p1Label" text="Player 1" styleClass="score-label"/>
                <Region styleClass="score-divider"/>
                <Label fx:id="p1ScoreLabel" text="0" styleClass="score-value"/>
            </HBox>

            <Region HBox.hgrow="ALWAYS"/>

            <HBox alignment="CENTER" spacing="8" styleClass="turn-pill">
                <Region styleClass="turn-ring"/>
                <Label fx:id="turnLabel" text="Player 1's Turn" styleClass="turn-label"/>
            </HBox>

            <Region HBox.hgrow="ALWAYS"/>

            <HBox fx:id="p2Chip" alignment="CENTER" spacing="16" styleClass="player-chip">
                <StackPane styleClass="player-icon">
                    <Label text="P" styleClass="player-icon-text"/>
                </StackPane>
                <Label fx:id="p2Label" text="Player 2" styleClass="score-label"/>
                <Region styleClass="score-divider"/>
                <Label fx:id="p2ScoreLabel" text="0" styleClass="score-value"/>
            </HBox>

            <Button text="Quit" onAction="#onQuit" styleClass="quit-button"/>
        </HBox>
    </top>

    <center>
        <StackPane styleClass="memory-game-stage">
            <VBox alignment="CENTER" spacing="14" maxWidth="Infinity" maxHeight="Infinity" styleClass="memory-board-card">
                <ImageView fitHeight="52.0" fitWidth="52.0" preserveRatio="true">
                    <image>
                        <Image url="@../icons/icons8-memory-game-64.png"/>
                    </image>
                </ImageView>

                <VBox alignment="CENTER" spacing="4">
                    <Label text="Memory Match" styleClass="board-title"/>
                    <Label text="Find all the matching pairs!" styleClass="board-subtitle"/>
                </VBox>

                <ScrollPane fx:id="memoryScroll"
                            fitToWidth="true"
                            fitToHeight="true"
                            hbarPolicy="NEVER"
                            vbarPolicy="NEVER"
                            maxWidth="Infinity"
                            maxHeight="Infinity"
                            VBox.vgrow="ALWAYS"
                            styleClass="memory-scroll">
                    <GridPane fx:id="cardGrid" alignment="CENTER"/>
                </ScrollPane>
            </VBox>
        </StackPane>
    </center>

    <bottom>
        <VBox alignment="CENTER" spacing="8" styleClass="memory-game-footer">
            <HBox fx:id="postGameBar" alignment="CENTER" spacing="20"
                  styleClass="post-game-bar"
                  visible="false" managed="false">
                <Label fx:id="resultLabel" styleClass="post-result"/>
                <Button fx:id="btnPostPlayAgain" text="Play Again" onAction="#onPostPlayAgain"
                        styleClass="btn-primary"/>
                <Button fx:id="btnPostMainMenu" text="Main Menu" onAction="#onPostMainMenu"
                        styleClass="btn-outline"/>
            </HBox>

            <Label fx:id="statusLabel" text="" styleClass="status-line"/>
        </VBox>
    </bottom>
</BorderPane>
