<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="seda_project.control_alt_defeat.gamebox.controller.memory.GameController"
            styleClass="memory-game-root">
    <stylesheets>
        <URL value="@Memory.css"/>
    </stylesheets>

    <top>
        <HBox alignment="CENTER" spacing="30" styleClass="score-bar">
            <Label fx:id="p1Label" text="Player 1: 0" styleClass="score-label"/>
            <Label fx:id="turnLabel" text="▶ Player 1's Turn" styleClass="turn-label"/>
            <Label fx:id="p2Label" text="Player 2: 0" styleClass="score-label"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="Quit" onAction="#onQuit" id="btnQuit"
                    styleClass="btn-danger"/>
        </HBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" fitToHeight="true" styleClass="memory-scroll">
            <GridPane fx:id="cardGrid" hgap="8" vgap="8" alignment="CENTER">
                <padding>
                    <Insets top="20" right="20" bottom="20" left="20"/>
                </padding>
            </GridPane>
        </ScrollPane>
    </center>

    <bottom>
        <VBox>
            <HBox fx:id="postGameBar" alignment="CENTER" spacing="20"
                  styleClass="post-game-bar"
                  visible="false" managed="false">
                <Label fx:id="resultLabel" styleClass="post-result"/>
                <Button fx:id="btnPostPlayAgain" text="▶ Play Again" onAction="#onPostPlayAgain"
                        styleClass="btn-primary"/>
                <Button fx:id="btnPostMainMenu" text="⇦ Main Menu" onAction="#onPostMainMenu"
                        styleClass="btn-outline"/>
            </HBox>
            <HBox alignment="CENTER" spacing="10" styleClass="status-bar">
                <Label fx:id="statusLabel" text="" styleClass="status-line"/>
            </HBox>
        </VBox>
    </bottom>
</BorderPane>
