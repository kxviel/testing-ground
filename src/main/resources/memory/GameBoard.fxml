<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane alignment="CENTER"
           prefWidth="1226.0"
           prefHeight="576.0"
           maxWidth="Infinity"
           maxHeight="Infinity"
           styleClass="memory-game-root"
           xmlns="http://javafx.com/javafx"
           xmlns:fx="http://javafx.com/fxml"
           fx:controller="seda_project.control_alt_defeat.gamebox.controller.memory.GameController">
    <stylesheets>
        <URL value="@Memory.css"/>
        <URL value="@game.css"/>
    </stylesheets>
    <padding>
        <Insets top="20.0" right="20.0" bottom="20.0" left="20.0"/>
    </padding>

    <GridPane alignment="CENTER"
              hgap="20.0"
              minWidth="0.0"
              maxWidth="Infinity"
              minHeight="480.0"
              prefHeight="544.0"
              maxHeight="Infinity"
              styleClass="memory-game-layout">
        <columnConstraints>
            <ColumnConstraints hgrow="ALWAYS" percentWidth="70.0"/>
            <ColumnConstraints hgrow="ALWAYS" percentWidth="30.0"/>
        </columnConstraints>

        <VBox GridPane.columnIndex="0"
              GridPane.hgrow="ALWAYS"
              GridPane.vgrow="ALWAYS"
              alignment="TOP_CENTER"
              minWidth="0.0"
              maxWidth="Infinity"
              minHeight="480.0"
              prefHeight="544.0"
              maxHeight="Infinity"
              spacing="20.0"
              styleClass="memory-board-panel">
            <padding>
                <Insets top="20.0" right="20.0" bottom="20.0" left="20.0"/>
            </padding>

            <VBox alignment="CENTER" spacing="8.0" styleClass="memory-board-header">
                <StackPane maxWidth="44.0" maxHeight="44.0" styleClass="memory-board-icon-tile">
                    <Label text="▦" styleClass="memory-board-icon"/>
                </StackPane>
                <Label text="Memory Match" styleClass="memory-game-title"/>
                <Label text="Find all the matching pairs." styleClass="memory-game-muted"/>
            </VBox>

            <StackPane fx:id="boardGridWrapper"
                       alignment="CENTER"
                       minWidth="0.0"
                       prefWidth="826.0"
                       maxWidth="Infinity"
                       maxHeight="Infinity"
                       styleClass="memory-grid-wrap"
                       VBox.vgrow="ALWAYS">
                <GridPane fx:id="cardGrid" alignment="CENTER" styleClass="memory-board-grid"/>
            </StackPane>
        </VBox>

        <VBox GridPane.columnIndex="1"
              GridPane.hgrow="ALWAYS"
              GridPane.vgrow="ALWAYS"
              alignment="TOP_LEFT"
              minWidth="0.0"
              maxWidth="Infinity"
              minHeight="480.0"
              prefHeight="544.0"
              maxHeight="Infinity"
              spacing="0.0"
              styleClass="memory-game-sidebar">
            <padding>
                <Insets top="20.0" right="20.0" bottom="20.0" left="20.0"/>
            </padding>

            <VBox spacing="8.0" styleClass="memory-sidebar-header">
                <Label text="Memory Match" styleClass="memory-sidebar-title"/>
                <Label text="Match in progress" styleClass="memory-game-muted"/>
                <Label fx:id="statusLabel" text="" wrapText="true" styleClass="memory-status"/>
            </VBox>

            <Separator styleClass="memory-section-separator"/>

            <VBox spacing="8.0" styleClass="memory-sidebar-section">
                <Label text="SCORE" styleClass="memory-section-label"/>
                <HBox fx:id="p1Chip" alignment="CENTER_LEFT" styleClass="memory-score-row">
                    <Label fx:id="p1Label" text="The Old Monk" styleClass="memory-score-label player-one-name" HBox.hgrow="ALWAYS"/>
                    <Label fx:id="p1ScoreLabel" text="0" styleClass="memory-score-value"/>
                </HBox>
                <HBox fx:id="p2Chip" alignment="CENTER_LEFT" styleClass="memory-score-row">
                    <Label fx:id="p2Label" text="The Outer God" styleClass="memory-score-label player-two-name" HBox.hgrow="ALWAYS"/>
                    <Label fx:id="p2ScoreLabel" text="0" styleClass="memory-score-value"/>
                </HBox>
            </VBox>

            <Separator styleClass="memory-section-separator"/>

            <VBox spacing="10.0" styleClass="memory-sidebar-section">
                <Label text="TURN" styleClass="memory-section-label"/>
                <HBox alignment="CENTER_LEFT" styleClass="memory-turn-pill">
                    <Region styleClass="memory-turn-dot"/>
                    <Label fx:id="turnLabel" text="The Old Monk's turn" styleClass="memory-turn-label"/>
                </HBox>
            </VBox>

            <HBox fx:id="postGameBar"
                  alignment="CENTER_LEFT"
                  spacing="10.0"
                  visible="false"
                  managed="false"
                  styleClass="memory-post-game-bar">
                <Label fx:id="resultLabel" wrapText="true" styleClass="memory-post-result" HBox.hgrow="ALWAYS"/>
                <Button text="Play Again" onAction="#onPostPlayAgain" styleClass="memory-primary-button"/>
                <Button text="Main Menu" onAction="#onPostMainMenu" styleClass="memory-secondary-button"/>
            </HBox>

            <Region VBox.vgrow="ALWAYS"/>

            <VBox spacing="8.0" styleClass="memory-game-actions">
                <Button text="↻  Restart"
                        onAction="#onRestart"
                        maxWidth="Infinity"
                        styleClass="memory-secondary-button"/>
                <Button text="↪  Quit to Menu"
                        onAction="#onQuit"
                        maxWidth="Infinity"
                        styleClass="memory-primary-button"/>
            </VBox>
        </VBox>
    </GridPane>
</StackPane>
