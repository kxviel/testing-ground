<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane prefWidth="1080.0"
           prefHeight="720.0"
           styleClass="memory-menu-root"
           xmlns="http://javafx.com/javafx"
           xmlns:fx="http://javafx.com/fxml"
           fx:controller="seda_project.control_alt_defeat.gamebox.controller.memory.MemoryMenuController">
    <stylesheets>
        <URL value="@Memory.css"/>
    </stylesheets>

    <ScrollPane fitToHeight="true"
                fitToWidth="true"
                hbarPolicy="AS_NEEDED"
                vbarPolicy="AS_NEEDED"
                styleClass="app-scroll">
        <GridPane alignment="TOP_CENTER"
                  minHeight="680"
                  minWidth="960"
                  maxHeight="Infinity"
                  maxWidth="Infinity"
                  styleClass="memory-menu-main">
        <columnConstraints>
            <ColumnConstraints hgrow="ALWAYS" percentWidth="65"/>
            <ColumnConstraints hgrow="ALWAYS" percentWidth="35"/>
        </columnConstraints>

        <VBox GridPane.columnIndex="0"
              GridPane.hgrow="ALWAYS"
              GridPane.vgrow="ALWAYS"
              maxHeight="Infinity"
              maxWidth="Infinity"
              spacing="26"
              styleClass="memory-setup">

            <VBox spacing="8" styleClass="hero-copy">
                <Label text="Multi Match Memory Game" styleClass="memory-menu-title"/>
                <Label text="Choose tuple size, board size, and start a match."
                       styleClass="memory-menu-subtitle"/>
            </VBox>

            <HBox alignment="CENTER" spacing="8" styleClass="title-divider">
                <Region minWidth="84" prefWidth="84" styleClass="divider-line-active"/>
                <Region styleClass="divider-seal"/>
                <Region HBox.hgrow="ALWAYS" styleClass="divider-line"/>
            </HBox>

            <VBox spacing="12" styleClass="memory-setup-list">
                <VBox spacing="8" styleClass="menu-section">
                    <HBox alignment="CENTER_LEFT" spacing="18">
                        <StackPane styleClass="section-icon">
                            <Label text="k" styleClass="section-icon-text"/>
                        </StackPane>
                        <Label text="Enter tuple size k (1-45):" styleClass="section-heading"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <TextField fx:id="kField" promptText="Enter k" text="2" maxWidth="150.0"/>
                        <Button fx:id="btnApplyK" text="Apply" onAction="#onApplyK" styleClass="btn-primary apply-button"/>
                    </HBox>
                    <Label fx:id="kErrorLabel" text="" wrapText="true" styleClass="error-label"/>
                </VBox>

                <VBox spacing="14" styleClass="menu-section">
                    <HBox alignment="CENTER_LEFT" spacing="18">
                        <StackPane styleClass="section-icon">
                            <Label text="#" styleClass="section-icon-text"/>
                        </StackPane>
                        <Label text="Select board variant:" styleClass="section-heading"/>
                    </HBox>

                    <VBox spacing="8" styleClass="variant-list">
                        <RadioButton fx:id="variant1Radio" maxWidth="Infinity"/>
                        <RadioButton fx:id="variant2Radio" maxWidth="Infinity"/>
                        <RadioButton fx:id="variant3Radio" maxWidth="Infinity"/>
                    </VBox>
                </VBox>

                <Region minHeight="1" styleClass="menu-divider"/>

                <Button fx:id="btnLocalGame"
                        maxWidth="Infinity"
                        onAction="#onLocalGame"
                        styleClass="memory-action-row">
                    <graphic>
                        <HBox alignment="CENTER_LEFT" maxWidth="Infinity" spacing="18" styleClass="row-content">
                            <StackPane styleClass="icon-chip">
                                <Label text="S" styleClass="icon-letter"/>
                            </StackPane>

                            <VBox spacing="4" HBox.hgrow="ALWAYS">
                                <Label text="Start Game" styleClass="row-title"/>
                                <Label text="Start local 2-player memory" styleClass="row-subtitle"/>
                            </VBox>

                            <StackPane styleClass="row-arrow-chip">
                                <Label text="›" styleClass="row-arrow"/>
                            </StackPane>
                        </HBox>
                    </graphic>
                </Button>

                <Button maxWidth="Infinity"
                        onAction="#onBack"
                        styleClass="memory-action-row">
                    <graphic>
                        <HBox alignment="CENTER_LEFT" maxWidth="Infinity" spacing="18" styleClass="row-content">
                            <StackPane styleClass="icon-chip">
                                <Label text="X" styleClass="icon-letter"/>
                            </StackPane>

                            <VBox spacing="4" HBox.hgrow="ALWAYS">
                                <Label text="Exit Game" styleClass="row-title"/>
                                <Label text="Return to GameBox" styleClass="row-subtitle"/>
                            </VBox>

                            <StackPane styleClass="row-arrow-chip">
                                <Label text="›" styleClass="row-arrow"/>
                            </StackPane>
                        </HBox>
                    </graphic>
                </Button>
            </VBox>

            <Region VBox.vgrow="ALWAYS"/>
        </VBox>

        <VBox GridPane.columnIndex="1"
              GridPane.hgrow="ALWAYS"
              GridPane.vgrow="ALWAYS"
              maxHeight="Infinity"
              maxWidth="Infinity"
              spacing="24"
              styleClass="memory-network-panel">

            <VBox spacing="8">
                <Label text="Network" styleClass="network-title"/>
                <Label text="Host or join LAN matches" styleClass="network-subtitle"/>
            </VBox>

            <VBox spacing="12" styleClass="network-section">
                <Button fx:id="btnHostGame" onAction="#onHostGame"
                        maxWidth="Infinity" styleClass="mode-button">
                    <graphic>
                        <HBox alignment="CENTER_LEFT" spacing="12">
                            <Label text="H" styleClass="mode-icon"/>
                            <Label text="Host LAN Game" styleClass="mode-text"/>
                        </HBox>
                    </graphic>
                </Button>

                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Button fx:id="btnRefreshGames"
                            text="Refresh"
                            onAction="#onRefreshLan"
                            maxWidth="Infinity"
                            styleClass="btn-outline"
                            HBox.hgrow="ALWAYS"/>
                    <Button fx:id="btnJoinSelectedGame"
                            text="Join Selected"
                            onAction="#onJoinSelectedLan"
                            maxWidth="Infinity"
                            styleClass="btn-outline"
                            HBox.hgrow="ALWAYS"/>
                </HBox>
            </VBox>

            <VBox spacing="8">
                <Label text="Available Games" styleClass="field-title"/>
                <ListView fx:id="availableGamesList" prefHeight="110" maxHeight="150" maxWidth="Infinity">
                    <placeholder>
                        <Label text="No LAN games found" styleClass="empty-list-label"/>
                    </placeholder>
                </ListView>
            </VBox>

            <Button fx:id="btnCancelHost" text="Cancel Hosting" onAction="#onCancelHost"
                    visible="false" managed="false"
                    maxWidth="Infinity"
                    styleClass="btn-danger"/>

            <Label fx:id="statusLabel" text="" wrapText="true" styleClass="status-line"/>

            <Region VBox.vgrow="ALWAYS"/>

            <VBox spacing="8" styleClass="network-footer">
                <Label text="Memory: Local or LAN" styleClass="footer-line"/>
                <Label text="Tuple matching with synchronized network play."
                       wrapText="true"
                       styleClass="footer-line"/>
            </VBox>
        </VBox>
        </GridPane>
    </ScrollPane>
</StackPane>
