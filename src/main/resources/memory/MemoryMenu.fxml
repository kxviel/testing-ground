<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.RadioButton?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Slider?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Rectangle?>
<?import seda_project.control_alt_defeat.gamebox.ui.SvgIcon?>

<StackPane prefWidth="1080.0"
           prefHeight="720.0"
           maxWidth="Infinity"
           maxHeight="Infinity"
           styleClass="memory-menu-root"
           xmlns="http://javafx.com/javafx"
           xmlns:fx="http://javafx.com/fxml"
           fx:controller="seda_project.control_alt_defeat.gamebox.controller.memory.MemoryMenuController">
    <stylesheets>
        <URL value="@Memory.css"/>
        <URL value="@../GameMenu.css"/>
    </stylesheets>

    <ScrollPane fitToHeight="true"
                fitToWidth="true"
                hbarPolicy="AS_NEEDED"
                vbarPolicy="AS_NEEDED"
                styleClass="memory-screen-scroll">
        <StackPane alignment="CENTER"
                   minWidth="0.0"
                   minHeight="0.0"
                   styleClass="memory-menu-viewport">
            <HBox alignment="CENTER"
                  minWidth="0.0"
                  minHeight="688.0"
                  maxWidth="Infinity"
                  prefHeight="688.0"
                  maxHeight="Infinity"
                  spacing="20.0"
                  styleClass="memory-menu-layout">

                <VBox minWidth="0.0"
                      maxWidth="Infinity"
                      minHeight="688.0"
                      prefHeight="688.0"
                      maxHeight="Infinity"
                      spacing="20.0"
                      HBox.hgrow="ALWAYS"
                      styleClass="memory-setup-card">
                    <padding>
                        <Insets top="20.0" right="20.0" bottom="20.0" left="20.0"/>
                    </padding>

                    <VBox spacing="8.0" styleClass="memory-copy-block">
                        <Label text="G A M E B O X" styleClass="memory-eyebrow"/>
                        <Label text="Multi Match Memory Game" styleClass="memory-menu-title"/>
                        <Label text="Choose tuple size, board size, and start a match." styleClass="memory-muted"/>
                    </VBox>

                    <VBox spacing="8.0" styleClass="memory-parameter-panel">
                        <HBox alignment="CENTER_LEFT" spacing="12.0">
                            <Label text="Tuple size (k = 1-45)" styleClass="memory-label"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <TextField fx:id="kField"
                                       text="2"
                                       promptText="2"
                                       prefWidth="80.0"
                                       styleClass="memory-input"/>
                            <Button fx:id="btnApplyK"
                                    text="Apply"
                                    onAction="#onApplyK"
                                    prefWidth="104.0"
                                    styleClass="memory-primary-button"/>
                        </HBox>
                        <Slider fx:id="kSlider"
                                min="1.0"
                                max="45.0"
                                value="2.0"
                                blockIncrement="1.0"
                                maxWidth="Infinity"
                                styleClass="memory-slider">
                            <clip>
                                <Rectangle fx:id="kSliderClip" height="18.0"/>
                            </clip>
                        </Slider>
                        <Label text="Match groups of k identical cards." styleClass="memory-caption"/>
                        <Label fx:id="kErrorLabel"
                               text=""
                               visible="false"
                               managed="false"
                               wrapText="true"
                               styleClass="memory-error"/>
                    </VBox>

                    <VBox spacing="8.0" styleClass="memory-variant-section">
                        <Label text="Board variant" styleClass="memory-label"/>
                        <VBox spacing="8.0" styleClass="memory-variant-list">
                            <RadioButton fx:id="variant1Radio"
                                         maxWidth="Infinity"
                                         styleClass="memory-variant-row">
                                <graphic>
                                    <HBox alignment="CENTER_LEFT" maxWidth="Infinity" spacing="12.0">
                                        <VBox spacing="2.0" HBox.hgrow="ALWAYS">
                                            <Label fx:id="variant1TitleLabel" styleClass="memory-row-title"/>
                                            <Label fx:id="variant1MetaLabel" styleClass="memory-row-subtitle"/>
                                        </VBox>
                                    </HBox>
                                </graphic>
                            </RadioButton>

                            <RadioButton fx:id="variant2Radio"
                                         maxWidth="Infinity"
                                         styleClass="memory-variant-row">
                                <graphic>
                                    <HBox alignment="CENTER_LEFT" maxWidth="Infinity" spacing="12.0">
                                        <VBox spacing="2.0" HBox.hgrow="ALWAYS">
                                            <Label fx:id="variant2TitleLabel" styleClass="memory-row-title"/>
                                            <Label fx:id="variant2MetaLabel" styleClass="memory-row-subtitle"/>
                                        </VBox>
                                    </HBox>
                                </graphic>
                            </RadioButton>

                            <RadioButton fx:id="variant3Radio"
                                         maxWidth="Infinity"
                                         styleClass="memory-variant-row">
                                <graphic>
                                    <HBox alignment="CENTER_LEFT" maxWidth="Infinity" spacing="12.0">
                                        <VBox spacing="2.0" HBox.hgrow="ALWAYS">
                                            <Label fx:id="variant3TitleLabel" styleClass="memory-row-title"/>
                                            <Label fx:id="variant3MetaLabel" styleClass="memory-row-subtitle"/>
                                        </VBox>
                                    </HBox>
                                </graphic>
                            </RadioButton>
                        </VBox>
                    </VBox>

                    <Region maxHeight="1.0" minHeight="1.0" prefHeight="1.0" styleClass="memory-divider"/>

                    <VBox spacing="8.0" styleClass="memory-action-list">
                        <Button fx:id="btnLocalGame"
                                maxWidth="Infinity"
                                onAction="#onLocalGame"
                                styleClass="memory-action-row">
                            <graphic>
                                <HBox alignment="CENTER_LEFT" maxWidth="Infinity" spacing="20.0">
                                    <StackPane styleClass="memory-icon-box">
                                        <SvgIcon icon="local" styleClass="svg-icon-primary"/>
                                    </StackPane>
                                    <VBox spacing="2.0" HBox.hgrow="ALWAYS">
                                        <Label text="Start Game" styleClass="memory-row-title"/>
                                        <Label text="Start local 2-player memory" styleClass="memory-row-subtitle"/>
                                    </VBox>
                                    <SvgIcon icon="chevron-right" styleClass="svg-icon-muted"/>
                                </HBox>
                            </graphic>
                        </Button>

                        <Button maxWidth="Infinity"
                                onAction="#onBack"
                                styleClass="memory-action-row">
                            <graphic>
                                <HBox alignment="CENTER_LEFT" maxWidth="Infinity" spacing="20.0">
                                    <StackPane styleClass="memory-danger-icon-box">
                                        <SvgIcon icon="exit" styleClass="svg-icon-danger"/>
                                    </StackPane>
                                    <VBox spacing="2.0" HBox.hgrow="ALWAYS">
                                        <Label text="Exit Game" styleClass="memory-row-title"/>
                                        <Label text="Return to GameBox" styleClass="memory-row-subtitle"/>
                                    </VBox>
                                    <SvgIcon icon="chevron-right" styleClass="svg-icon-muted"/>
                                </HBox>
                            </graphic>
                        </Button>
                    </VBox>
                </VBox>

                <VBox prefWidth="320.0"
                      minWidth="320.0"
                      maxWidth="Infinity"
                      minHeight="688.0"
                      prefHeight="688.0"
                      maxHeight="Infinity"
                      spacing="24.0"
                      HBox.hgrow="SOMETIMES"
                      styleClass="memory-network-card">
                    <padding>
                        <Insets top="20.0" right="20.0" bottom="20.0" left="20.0"/>
                    </padding>

                    <VBox spacing="8.0" styleClass="memory-copy-block">
                        <Label text="N E T W O R K" styleClass="memory-eyebrow"/>
                        <Label text="Host or join LAN matches." styleClass="memory-muted"/>
                    </VBox>

                    <Button fx:id="btnHostGame"
                            onAction="#onHostGame"
                            maxWidth="Infinity"
                            styleClass="memory-action-row">
                        <graphic>
                            <HBox alignment="CENTER_LEFT" maxWidth="Infinity" spacing="20.0">
                                <StackPane styleClass="memory-icon-box">
                                    <SvgIcon icon="lan" styleClass="svg-icon-primary"/>
                                </StackPane>
                                <VBox spacing="2.0" HBox.hgrow="ALWAYS">
                                    <Label text="Host LAN Game" styleClass="memory-row-title"/>
                                    <Label text="Make your match discover..." styleClass="memory-row-subtitle"/>
                                </VBox>
                                <SvgIcon icon="chevron-right" styleClass="svg-icon-muted"/>
                            </HBox>
                        </graphic>
                    </Button>

                    <HBox alignment="CENTER_LEFT" spacing="10.0">
                        <Button fx:id="btnRefreshGames"
                                text="↻  Refresh"
                                onAction="#onRefreshLan"
                                maxWidth="Infinity"
                                HBox.hgrow="ALWAYS"
                                styleClass="memory-secondary-button"/>
                        <Button fx:id="btnJoinSelectedGame"
                                text="↪  Join"
                                onAction="#onJoinSelectedLan"
                                maxWidth="Infinity"
                                HBox.hgrow="ALWAYS"
                                styleClass="memory-secondary-button"/>
                    </HBox>

                    <VBox spacing="10.0">
                        <Label text="Available games" styleClass="memory-label"/>
                        <ListView fx:id="availableGamesList"
                                  prefHeight="128.0"
                                  maxHeight="128.0"
                                  maxWidth="Infinity"
                                  styleClass="memory-empty-list">
                            <placeholder>
                                <VBox alignment="CENTER" spacing="6.0">
                                    <Label text="No games found" styleClass="memory-empty-title"/>
                                    <Label text="Refresh to scan your LAN." styleClass="memory-caption"/>
                                </VBox>
                            </placeholder>
                        </ListView>
                    </VBox>

                    <Button fx:id="btnCancelHost"
                            text="Cancel Hosting"
                            onAction="#onCancelHost"
                            visible="false"
                            managed="false"
                            maxWidth="Infinity"
                            styleClass="memory-secondary-button"/>

                    <Label fx:id="statusLabel"
                           text=""
                           visible="false"
                           managed="false"
                           wrapText="true"
                           styleClass="memory-status"/>

                    <Region VBox.vgrow="ALWAYS"/>

                    <VBox spacing="2.0" styleClass="memory-network-footer">
                        <Label text="Memory · Local or LAN" styleClass="memory-footer-title"/>
                        <Label text="Tuple matching with synchronized network play."
                               wrapText="true"
                               styleClass="memory-caption"/>
                    </VBox>
                </VBox>
            </HBox>
        </StackPane>
    </ScrollPane>
</StackPane>
