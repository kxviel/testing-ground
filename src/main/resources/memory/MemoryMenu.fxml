<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import java.net.URL?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.RadioButton?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane prefWidth="1080.0"
           prefHeight="720.0"
           maxWidth="Infinity"
           maxHeight="Infinity"
           styleClass="memory-menu-root"
           xmlns="http://javafx.com/javafx"
           xmlns:fx="http://javafx.com/fxml"
           fx:controller="seda_project.control_alt_defeat.gamebox.controller.memory.MemoryMenuController">
    <stylesheets>
        <URL value="@Memory.css"/>
        <URL value="@../GameMenu.css"/>
    </stylesheets>

    <ScrollPane fitToHeight="true"
                fitToWidth="true"
                hbarPolicy="AS_NEEDED"
                vbarPolicy="AS_NEEDED"
                styleClass="memory-screen-scroll">
        <StackPane alignment="CENTER"
                   minWidth="0.0"
                   minHeight="580.0"
                   styleClass="memory-menu-viewport">
            <GridPane fx:id="memoryMenuLayout"
                      alignment="CENTER"
                      hgap="20.0"
                      minWidth="0.0"
                      maxWidth="Infinity"
                      maxHeight="Infinity"
                      styleClass="memory-menu-layout">
                <columnConstraints>
                    <ColumnConstraints hgrow="ALWAYS" percentWidth="60.0"/>
                    <ColumnConstraints hgrow="ALWAYS" percentWidth="40.0"/>
                </columnConstraints>

                <VBox GridPane.columnIndex="0"
                      GridPane.hgrow="ALWAYS"
                      GridPane.vgrow="ALWAYS"
                      minWidth="0.0"
                      maxWidth="Infinity"
                      maxHeight="Infinity"
                      spacing="20.0"
                      styleClass="memory-setup-card">
                    <VBox spacing="8.0" styleClass="memory-copy-block">
                        <Label text="G A M E B O X" styleClass="memory-eyebrow"/>
                        <Label text="Multi Match Memory Game" styleClass="memory-menu-title"/>
                        <Label text="Choose tuple size, board size, and start a match." styleClass="memory-muted"/>
                    </VBox>

                    <VBox spacing="10.0" styleClass="memory-parameter-panel">
                        <Label text="Tuple size (k = 1-45)" styleClass="memory-label"/>
                        <HBox alignment="CENTER_LEFT" spacing="12.0" styleClass="memory-k-controls">
                            <TextField fx:id="kField"
                                       text="2"
                                       promptText="2"
                                       prefWidth="80.0"
                                       styleClass="memory-input"/>
                            <Button fx:id="btnApplyK"
                                    text="Apply"
                                    onAction="#onApplyK"
                                    prefWidth="104.0"
                                    styleClass="memory-primary-button"/>
                        </HBox>
                        <Label text="Match groups of k identical cards." styleClass="memory-caption"/>
                        <Label fx:id="kErrorLabel"
                               text=""
                               visible="false"
                               managed="false"
                               wrapText="true"
                               styleClass="memory-error"/>
                    </VBox>

                    <VBox spacing="8.0" styleClass="memory-variant-section">
                        <Label text="Board variant" styleClass="memory-label"/>
                        <VBox spacing="8.0" styleClass="memory-variant-list">
                            <RadioButton fx:id="variant1Radio"
                                         maxWidth="Infinity"
                                         styleClass="memory-variant-row">
                                <graphic>
                                    <HBox alignment="CENTER_LEFT"
                                          maxWidth="Infinity"
                                          styleClass="memory-variant-content">
                                        <VBox spacing="2.0" HBox.hgrow="ALWAYS">
                                            <Label fx:id="variant1TitleLabel" styleClass="memory-row-title"/>
                                            <Label fx:id="variant1MetaLabel" styleClass="memory-row-subtitle"/>
                                        </VBox>
                                    </HBox>
                                </graphic>
                            </RadioButton>

                            <RadioButton fx:id="variant2Radio"
                                         maxWidth="Infinity"
                                         styleClass="memory-variant-row">
                                <graphic>
                                    <HBox alignment="CENTER_LEFT"
                                          maxWidth="Infinity"
                                          styleClass="memory-variant-content">
                                        <VBox spacing="2.0" HBox.hgrow="ALWAYS">
                                            <Label fx:id="variant2TitleLabel" styleClass="memory-row-title"/>
                                            <Label fx:id="variant2MetaLabel" styleClass="memory-row-subtitle"/>
                                        </VBox>
                                    </HBox>
                                </graphic>
                            </RadioButton>

                            <RadioButton fx:id="variant3Radio"
                                         maxWidth="Infinity"
                                         styleClass="memory-variant-row">
                                <graphic>
                                    <HBox alignment="CENTER_LEFT"
                                          maxWidth="Infinity"
                                          styleClass="memory-variant-content">
                                        <VBox spacing="2.0" HBox.hgrow="ALWAYS">
                                            <Label fx:id="variant3TitleLabel" styleClass="memory-row-title"/>
                                            <Label fx:id="variant3MetaLabel" styleClass="memory-row-subtitle"/>
                                        </VBox>
                                    </HBox>
                                </graphic>
                            </RadioButton>
                        </VBox>
                    </VBox>

                    <Region maxHeight="1.0" minHeight="1.0" prefHeight="1.0" styleClass="memory-divider"/>

                    <VBox spacing="8.0" styleClass="memory-action-list">
                        <Button fx:id="btnLocalGame"
                                maxWidth="Infinity"
                                onAction="#onLocalGame">
                            <styleClass>
                                <String fx:value="memory-action-row"/>
                                <String fx:value="game-start-button"/>
                            </styleClass>
                            <graphic>
                                <HBox alignment="CENTER_LEFT" maxWidth="Infinity" spacing="20.0">
                                    <StackPane styleClass="memory-icon-box">
                                        <ImageView fitHeight="24.0" fitWidth="24.0" preserveRatio="true" smooth="true" styleClass="menu-icon">
                                            <image>
                                                <Image url="@../icons/play.png"/>
                                            </image>
                                        </ImageView>
                                    </StackPane>
                                    <VBox spacing="2.0" HBox.hgrow="ALWAYS">
                                        <Label text="Start Game" styleClass="memory-row-title"/>
                                        <Label text="Start local 2-player memory" styleClass="memory-row-subtitle"/>
                                    </VBox>
                                    <ImageView fitHeight="20.0" fitWidth="20.0" preserveRatio="true" smooth="true" styleClass="row-arrow-icon">
                                        <image>
                                            <Image url="@../icons/chevron-right.png"/>
                                        </image>
                                    </ImageView>
                                </HBox>
                            </graphic>
                        </Button>

                        <Button maxWidth="Infinity"
                                onAction="#onBack"
                                styleClass="memory-action-row">
                            <graphic>
                                <HBox alignment="CENTER_LEFT" maxWidth="Infinity" spacing="20.0">
                                    <StackPane styleClass="memory-danger-icon-box">
                                        <ImageView fitHeight="24.0" fitWidth="24.0" preserveRatio="true" smooth="true" styleClass="menu-icon-danger">
                                            <image>
                                                <Image url="@../icons/exit.png"/>
                                            </image>
                                        </ImageView>
                                    </StackPane>
                                    <VBox spacing="2.0" HBox.hgrow="ALWAYS">
                                        <Label text="Exit Game" styleClass="memory-row-title"/>
                                        <Label text="Return to GameBox" styleClass="memory-row-subtitle"/>
                                    </VBox>
                                    <ImageView fitHeight="20.0" fitWidth="20.0" preserveRatio="true" smooth="true" styleClass="row-arrow-icon">
                                        <image>
                                            <Image url="@../icons/chevron-right.png"/>
                                        </image>
                                    </ImageView>
                                </HBox>
                            </graphic>
                        </Button>
                    </VBox>
                </VBox>

                <VBox GridPane.columnIndex="1"
                      GridPane.hgrow="ALWAYS"
                      GridPane.vgrow="ALWAYS"
                      minWidth="0.0"
                      maxWidth="Infinity"
                      maxHeight="Infinity"
                      spacing="24.0"
                      HBox.hgrow="SOMETIMES"
                      styleClass="memory-network-card">
                    <VBox spacing="8.0" styleClass="memory-copy-block">
                        <Label text="N E T W O R K" styleClass="memory-eyebrow"/>
                        <Label text="Set players, host, or join LAN matches." styleClass="memory-muted"/>
                    </VBox>

                    <VBox spacing="12.0" styleClass="side-section">
                        <Label text="Players" styleClass="memory-label"/>
                        <GridPane styleClass="network-player-grid">
                            <columnConstraints>
                                <ColumnConstraints halignment="RIGHT" minWidth="104.0" prefWidth="104.0"/>
                                <ColumnConstraints hgrow="ALWAYS" minWidth="130.0"/>
                            </columnConstraints>

                            <Label text="Player 1" graphicTextGap="6.0" styleClass="player-one-name" GridPane.columnIndex="0" GridPane.rowIndex="0">
                                <graphic>
                                    <ImageView fitHeight="27.0" fitWidth="27.0" preserveRatio="true" smooth="true" styleClass="player-field-icon">
                                        <image>
                                            <Image url="@../icons/player1.png"/>
                                        </image>
                                    </ImageView>
                                </graphic>
                            </Label>
                            <TextField fx:id="playerOneNameField"
                                       text="The Old Monk"
                                       promptText="The Old Monk"
                                       GridPane.columnIndex="1"
                                       GridPane.rowIndex="0">
                                <styleClass>
                                    <String fx:value="player-name-field"/>
                                    <String fx:value="player-one-name"/>
                                </styleClass>
                            </TextField>

                            <Label text="Player 2" graphicTextGap="6.0" styleClass="player-two-name" GridPane.columnIndex="0" GridPane.rowIndex="1">
                                <graphic>
                                    <ImageView fitHeight="27.0" fitWidth="27.0" preserveRatio="true" smooth="true" styleClass="player-field-icon">
                                        <image>
                                            <Image url="@../icons/player2.png"/>
                                        </image>
                                    </ImageView>
                                </graphic>
                            </Label>
                            <TextField fx:id="playerTwoNameField"
                                       text="The Outer God"
                                       promptText="The Outer God"
                                       GridPane.columnIndex="1"
                                       GridPane.rowIndex="1">
                                <styleClass>
                                    <String fx:value="player-name-field"/>
                                    <String fx:value="player-two-name"/>
                                </styleClass>
                            </TextField>
                        </GridPane>
                    </VBox>

                    <VBox spacing="12.0" styleClass="network-section">
                        <HBox alignment="CENTER_LEFT" spacing="10.0">
                            <Button fx:id="btnHostGameIcon"
                                    onAction="#onHostGame"
                                    styleClass="network-host-icon-button">
                                <graphic>
                                    <ImageView fitHeight="24.0" fitWidth="24.0" preserveRatio="true" smooth="true" styleClass="menu-icon">
                                        <image>
                                            <Image url="@../icons/lan.png"/>
                                        </image>
                                    </ImageView>
                                </graphic>
                            </Button>
                            <Button fx:id="btnHostGame"
                                    text="Host LAN Game"
                                    onAction="#onHostGame"
                                    maxWidth="Infinity"
                                    HBox.hgrow="ALWAYS"
                                    styleClass="network-host-button"/>
                        </HBox>

                        <HBox alignment="CENTER_LEFT" spacing="10.0">
                            <Button fx:id="btnRefreshGames"
                                    text="Refresh"
                                    onAction="#onRefreshLan"
                                    maxWidth="Infinity"
                                    HBox.hgrow="ALWAYS"
                                    styleClass="memory-secondary-button"/>
                            <Button fx:id="btnJoinSelectedGame"
                                    text="Join Selected"
                                    onAction="#onJoinSelectedLan"
                                    maxWidth="Infinity"
                                    HBox.hgrow="ALWAYS"
                                    styleClass="memory-secondary-button"/>
                        </HBox>
                    </VBox>

                    <VBox spacing="10.0">
                        <Label text="Available Games" styleClass="memory-label"/>
                        <ListView fx:id="availableGamesList"
                                  prefHeight="128.0"
                                  maxHeight="160.0"
                                  maxWidth="Infinity"
                                  styleClass="memory-empty-list">
                            <placeholder>
                                <VBox alignment="CENTER" spacing="6.0">
                                    <Label text="No LAN games found" styleClass="memory-empty-title"/>
                                </VBox>
                            </placeholder>
                        </ListView>
                    </VBox>

                    <Button fx:id="btnCancelHost"
                            text="Cancel Hosting"
                            onAction="#onCancelHost"
                            visible="false"
                            managed="false"
                            maxWidth="Infinity"
                            styleClass="memory-secondary-button"/>

                    <Label fx:id="statusLabel"
                           text=""
                           visible="false"
                           managed="false"
                           wrapText="true"
                           styleClass="memory-status"/>

                    <Region VBox.vgrow="ALWAYS"/>

                    <VBox spacing="2.0" styleClass="memory-network-footer">
                        <Label text="Memory · Local or LAN" styleClass="memory-footer-title"/>
                        <Label text="Tuple matching with synchronized network play."
                               wrapText="true"
                               styleClass="memory-caption"/>
                    </VBox>
                </VBox>
            </GridPane>
        </StackPane>
    </ScrollPane>
</StackPane>
