<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import seda_project.control_alt_defeat.gamebox.ui.SvgIcon?>

<StackPane prefWidth="1080.0"
           prefHeight="720.0"
           maxHeight="Infinity"
           maxWidth="Infinity"
           styleClass="hex-menu-root"
           xmlns="http://javafx.com/javafx"
           xmlns:fx="http://javafx.com/fxml"
           fx:controller="seda_project.control_alt_defeat.gamebox.controller.hexchess.HexChessMenuController">

    <stylesheets>
        <URL value="@HexChess.css"/>
        <URL value="@../GameMenu.css"/>
    </stylesheets>

    <ScrollPane fitToHeight="true"
                fitToWidth="true"
                hbarPolicy="AS_NEEDED"
                vbarPolicy="AS_NEEDED"
                styleClass="app-scroll">
        <StackPane alignment="CENTER"
                   minHeight="0"
                   minWidth="0"
                   maxHeight="Infinity"
                   maxWidth="Infinity"
                   styleClass="game-menu-shell">
        <GridPane alignment="CENTER"
                  minHeight="688"
                  minWidth="0"
                  maxHeight="Infinity"
                  maxWidth="Infinity"
                  styleClass="hex-menu-main">
        <columnConstraints>
            <ColumnConstraints hgrow="ALWAYS" percentWidth="60"/>
            <ColumnConstraints hgrow="ALWAYS" percentWidth="40"/>
        </columnConstraints>

        <VBox GridPane.columnIndex="0"
              GridPane.hgrow="ALWAYS"
              GridPane.vgrow="ALWAYS"
              maxHeight="Infinity"
              maxWidth="Infinity"
              spacing="26"
              styleClass="hex-setup">

            <VBox styleClass="menu-header">
                <Label text="C H E S S" styleClass="text-muted-caps"/>
                <Label text="Chexsagon" styleClass="title"/>
                <Label text="Choose players, setup, and start a match."
                       styleClass="subtitle"/>
            </VBox>

            <VBox spacing="12" styleClass="hex-setup-list">
                <Button maxWidth="Infinity"
                        onAction="#onStartLocal"
                        styleClass="hex-action-row">
                    <graphic>
                        <HBox alignment="CENTER_LEFT" maxWidth="Infinity" spacing="20" styleClass="row-content">
                            <StackPane styleClass="row-icon-chip">
                                <SvgIcon icon="local" styleClass="svg-icon-primary"/>
                            </StackPane>

                            <VBox spacing="4" HBox.hgrow="ALWAYS">
                                <Label text="Start Local" styleClass="row-title"/>
                                <Label text="Start a two-player local match" styleClass="row-subtitle"/>
                            </VBox>

                            <StackPane styleClass="row-arrow-chip">
                                <SvgIcon icon="chevron-right" styleClass="svg-icon-muted"/>
                            </StackPane>
                        </HBox>
                    </graphic>
                </Button>

                <Button maxWidth="Infinity"
                        onAction="#onStartBot"
                        styleClass="hex-action-row">
                    <graphic>
                        <HBox alignment="CENTER_LEFT" maxWidth="Infinity" spacing="20" styleClass="row-content">
                            <StackPane styleClass="row-icon-chip">
                                <SvgIcon icon="bot" styleClass="svg-icon-primary"/>
                            </StackPane>

                            <VBox spacing="4" HBox.hgrow="ALWAYS">
                                <Label text="Play Bot" styleClass="row-title"/>
                                <Label text="Play White against the computer" styleClass="row-subtitle"/>
                            </VBox>

                            <StackPane styleClass="row-arrow-chip">
                                <SvgIcon icon="chevron-right" styleClass="svg-icon-muted"/>
                            </StackPane>
                        </HBox>
                    </graphic>
                </Button>

                <Button maxWidth="Infinity"
                        onAction="#onCustomSetup"
                        styleClass="hex-action-row">
                    <graphic>
                        <HBox alignment="CENTER_LEFT" maxWidth="Infinity" spacing="20" styleClass="row-content">
                            <StackPane styleClass="row-icon-chip">
                                <SvgIcon icon="custom" styleClass="svg-icon-primary"/>
                            </StackPane>

                            <VBox spacing="4" HBox.hgrow="ALWAYS">
                                <Label text="Custom Setup" styleClass="row-title"/>
                                <Label text="Build a custom starting position" styleClass="row-subtitle"/>
                            </VBox>

                            <StackPane styleClass="row-arrow-chip">
                                <SvgIcon icon="chevron-right" styleClass="svg-icon-muted"/>
                            </StackPane>
                        </HBox>
                    </graphic>
                </Button>

                <Region minHeight="1" styleClass="menu-divider"/>

                <Button maxWidth="Infinity"
                        onAction="#onBack"
                        styleClass="hex-action-row">
                    <graphic>
                        <HBox alignment="CENTER_LEFT" maxWidth="Infinity" spacing="20" styleClass="row-content">
                            <StackPane styleClass="row-icon-chip-danger">
                                <SvgIcon icon="exit" styleClass="svg-icon-danger"/>
                            </StackPane>

                            <VBox spacing="4" HBox.hgrow="ALWAYS">
                                <Label text="Exit Game" styleClass="row-title"/>
                                <Label text="Return to GameBox" styleClass="row-subtitle"/>
                            </VBox>

                            <StackPane styleClass="row-arrow-chip">
                                <SvgIcon icon="chevron-right" styleClass="svg-icon-muted"/>
                            </StackPane>
                        </HBox>
                    </graphic>
                </Button>
            </VBox>

            <Region VBox.vgrow="ALWAYS"/>
        </VBox>

        <VBox GridPane.columnIndex="1"
              GridPane.hgrow="ALWAYS"
              GridPane.vgrow="ALWAYS"
              maxHeight="Infinity"
              maxWidth="Infinity"
              spacing="14"
              styleClass="hex-network-panel">

            <VBox styleClass="menu-header">
                <Label text="N E T W O R K" styleClass="text-muted-caps"/>
                <Label text="Set players, host, or join LAN matches." styleClass="network-subtitle"/>
            </VBox>

            <VBox spacing="12" styleClass="side-section">
                <Label text="Players" styleClass="field-title"/>

                <GridPane styleClass="network-player-grid">
                    <columnConstraints>
                        <ColumnConstraints halignment="RIGHT" minWidth="78" prefWidth="78"/>
                        <ColumnConstraints hgrow="ALWAYS" minWidth="170"/>
                    </columnConstraints>

                    <Label text="White" styleClass="player-one-name" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                    <TextField fx:id="playerOneNameField"
                               text="The Old Monk"
                               promptText="The Old Monk"
                               styleClass="player-name-field player-one-name"
                               GridPane.columnIndex="1"
                               GridPane.rowIndex="0"/>

                    <Label text="Black" styleClass="player-two-name" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                    <TextField fx:id="playerTwoNameField"
                               text="The Outer God"
                               promptText="The Outer God"
                               styleClass="player-name-field player-two-name"
                               GridPane.columnIndex="1"
                               GridPane.rowIndex="1"/>
                </GridPane>
            </VBox>

            <VBox spacing="12" styleClass="network-section">
                <Button maxWidth="Infinity" onAction="#onHostLan" styleClass="network-host-button">
                    <graphic>
                        <HBox alignment="CENTER_LEFT" maxWidth="Infinity" spacing="12">
                            <SvgIcon icon="lan" styleClass="svg-icon-primary"/>
                            <Label text="Host LAN Game" styleClass="mode-text"/>
                        </HBox>
                    </graphic>
                </Button>

                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Button text="Refresh" onAction="#onRefreshLan" maxWidth="Infinity"
                            styleClass="btn-secondary" HBox.hgrow="ALWAYS"/>
                    <Button fx:id="joinSelectedLanButton" text="Join Selected"
                            onAction="#onJoinSelectedLan" maxWidth="Infinity"
                            styleClass="btn-secondary" HBox.hgrow="ALWAYS"/>
                </HBox>
            </VBox>

            <VBox spacing="8">
                <Label text="Available Games" styleClass="field-title"/>
                <ListView fx:id="lanGamesList" prefHeight="128" maxHeight="160" maxWidth="Infinity"
                          styleClass="match-list">
                    <placeholder>
                        <Label text="No LAN games found" styleClass="empty-list-label"/>
                    </placeholder>
                </ListView>
            </VBox>

            <Label fx:id="statusLabel" text="" wrapText="true" maxWidth="Infinity" styleClass="status-line"/>

            <Region VBox.vgrow="ALWAYS"/>

            <VBox spacing="8" styleClass="network-footer">
                <Label text="Chexsagon: Local, Bot, or LAN" styleClass="footer-title"/>
                <Label text="Glinski-style hex chess with synchronized network play."
                       wrapText="true"
                       styleClass="footer-line"/>
            </VBox>
        </VBox>
        </GridPane>
        </StackPane>
    </ScrollPane>
</StackPane>
