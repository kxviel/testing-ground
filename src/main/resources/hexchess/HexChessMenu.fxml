<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox alignment="TOP_CENTER"
      styleClass="hex-menu-root"
      xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="seda_project.control_alt_defeat.gamebox.controller.hexchess.HexChessMenuController">

    <stylesheets>
        <URL value="@HexChess.css"/>
    </stylesheets>

    <padding>
        <Insets top="28" right="36" bottom="28" left="36"/>
    </padding>

    <VBox alignment="CENTER" styleClass="hex-header">
        <Label text="GLINSKI VARIANT" styleClass="eyebrow"/>
        <Label text="Chexsagon" styleClass="title"/>
        <Label text="Local board, bot, or LAN match" styleClass="subtitle"/>
    </VBox>

    <HBox alignment="TOP_CENTER" styleClass="hex-menu-layout">
        <VBox styleClass="menu-card">
            <Label text="Players" styleClass="section-title"/>
            <Label text="Set names once, then launch a local game, bot game, or custom board."
                   wrapText="true" styleClass="section-copy"/>

            <GridPane styleClass="hex-form-grid">
                <columnConstraints>
                    <ColumnConstraints halignment="RIGHT" minWidth="58" prefWidth="58"/>
                    <ColumnConstraints hgrow="ALWAYS" minWidth="190" prefWidth="210"/>
                </columnConstraints>

                <Label text="White" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                <TextField fx:id="whiteNameField" text="White" promptText="White player"
                           GridPane.columnIndex="1" GridPane.rowIndex="0"/>

                <Label text="Black" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                <TextField fx:id="blackNameField" text="Black" promptText="Black player"
                           GridPane.columnIndex="1" GridPane.rowIndex="1"/>
            </GridPane>

            <Label text="Quick Start" styleClass="panel-label"/>
            <VBox alignment="CENTER" styleClass="menu-action-stack">
                <Button text="Start Local" onAction="#onStartLocal" maxWidth="Infinity" styleClass="btn-primary"/>
                <Button text="Play Bot" onAction="#onStartBot" maxWidth="Infinity" styleClass="btn-outline"/>
                <Button text="Custom Setup" onAction="#onCustomSetup" maxWidth="Infinity" styleClass="btn-outline"/>
            </VBox>
        </VBox>

        <VBox styleClass="menu-card">
            <HBox alignment="CENTER_LEFT" styleClass="section-header">
                <VBox spacing="2">
                    <Label text="LAN" styleClass="section-title"/>
                    <Label text="Discover hosts automatically or connect directly by IP."
                           wrapText="true" styleClass="section-copy"/>
                </VBox>
                <Pane HBox.hgrow="ALWAYS"/>
                <Button text="Refresh" onAction="#onRefreshLan" styleClass="btn-small"/>
            </HBox>

            <HBox alignment="CENTER_LEFT" styleClass="button-row">
                <Button text="Host LAN" onAction="#onHostLan" styleClass="btn-outline"/>
                <Button fx:id="joinSelectedLanButton" text="Join Selected"
                        onAction="#onJoinSelectedLan" styleClass="btn-outline"/>
            </HBox>

            <ListView fx:id="lanGamesList" prefHeight="92" maxHeight="104" maxWidth="Infinity">
                <placeholder>
                    <Label text="No LAN games found" styleClass="empty-list-label"/>
                </placeholder>
            </ListView>

            <Separator/>
            <Label text="Direct Join" styleClass="panel-label"/>

            <GridPane styleClass="hex-form-grid">
                <columnConstraints>
                    <ColumnConstraints halignment="RIGHT" minWidth="58" prefWidth="58"/>
                    <ColumnConstraints hgrow="ALWAYS" minWidth="190" prefWidth="210"/>
                </columnConstraints>
                <Label text="Host IP" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                <TextField fx:id="lanHostField" promptText="192.168.1.20"
                           GridPane.columnIndex="1" GridPane.rowIndex="0"/>
                <Label text="Port" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                <TextField fx:id="lanPortField" promptText="54321" text="54321"
                           GridPane.columnIndex="1" GridPane.rowIndex="1"/>
            </GridPane>

            <Button text="Join LAN" onAction="#onJoinLan" maxWidth="Infinity" styleClass="btn-outline"/>

            <Label fx:id="statusLabel" wrapText="true" maxWidth="Infinity" minHeight="44"
                   styleClass="status-box"/>
        </VBox>
    </HBox>

    <HBox alignment="CENTER" styleClass="hex-footer">
        <Button text="Back" onAction="#onBack" styleClass="btn-outline"/>
    </HBox>
</VBox>
