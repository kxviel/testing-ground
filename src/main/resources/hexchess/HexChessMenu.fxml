<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import java.net.URL?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane prefWidth="1080.0"
           prefHeight="720.0"
           maxHeight="Infinity"
           maxWidth="Infinity"
           styleClass="hex-menu-root"
           xmlns="http://javafx.com/javafx"
           xmlns:fx="http://javafx.com/fxml"
           fx:controller="seda_project.control_alt_defeat.gamebox.controller.hexchess.HexChessMenuController">

    <stylesheets>
        <URL value="@HexChess.css"/>
        <URL value="@../GameMenu.css"/>
    </stylesheets>

    <ScrollPane fitToHeight="true"
                fitToWidth="true"
                hbarPolicy="AS_NEEDED"
                vbarPolicy="AS_NEEDED"
                styleClass="app-scroll">
        <StackPane alignment="CENTER"
                   minHeight="560"
                   minWidth="0"
                   maxHeight="Infinity"
                   maxWidth="Infinity"
                   styleClass="game-menu-shell">
        <GridPane fx:id="hexMenuMain"
                  alignment="CENTER"
                  minWidth="0"
                  maxHeight="Infinity"
                  maxWidth="Infinity"
                  styleClass="hex-menu-main">
        <columnConstraints>
            <ColumnConstraints hgrow="ALWAYS" percentWidth="60"/>
            <ColumnConstraints hgrow="ALWAYS" percentWidth="40"/>
        </columnConstraints>

        <VBox GridPane.columnIndex="0"
              GridPane.hgrow="ALWAYS"
              GridPane.vgrow="ALWAYS"
              maxHeight="Infinity"
              maxWidth="Infinity"
              spacing="26"
              styleClass="hex-setup">

            <VBox styleClass="menu-header">
                <Label text="C H E S S" styleClass="text-muted-caps"/>
                <Label text="Chexsagon" styleClass="title"/>
                <Label text="Choose players, setup, and start a match."
                       styleClass="subtitle"/>
            </VBox>

            <VBox spacing="16" styleClass="hex-setup-list">
                <Button maxWidth="Infinity"
                        onAction="#onStartLocal">
                    <styleClass>
                        <String fx:value="hex-action-row"/>
                        <String fx:value="game-start-button"/>
                    </styleClass>
                    <graphic>
                        <HBox alignment="CENTER_LEFT" maxWidth="Infinity" spacing="22" styleClass="row-content">
                            <StackPane styleClass="row-icon-chip">
                                <ImageView fitHeight="26.0" fitWidth="26.0" preserveRatio="true" smooth="true" styleClass="menu-icon">
                                    <image>
                                        <Image url="@../icons/local.png"/>
                                    </image>
                                </ImageView>
                            </StackPane>

                            <VBox spacing="4" HBox.hgrow="ALWAYS">
                                <Label text="Start Local" styleClass="row-title"/>
                                <Label text="Start a two-player local match" styleClass="row-subtitle"/>
                            </VBox>

                            <StackPane styleClass="row-arrow-chip">
                                <ImageView fitHeight="20.0" fitWidth="20.0" preserveRatio="true" smooth="true" styleClass="row-arrow-icon">
                                    <image>
                                        <Image url="@../icons/chevron-right.png"/>
                                    </image>
                                </ImageView>
                            </StackPane>
                        </HBox>
                    </graphic>
                </Button>

                <Button maxWidth="Infinity"
                        onAction="#onStartBot">
                    <styleClass>
                        <String fx:value="hex-action-row"/>
                        <String fx:value="game-start-button"/>
                    </styleClass>
                    <graphic>
                        <HBox alignment="CENTER_LEFT" maxWidth="Infinity" spacing="22" styleClass="row-content">
                            <StackPane styleClass="row-icon-chip">
                                <ImageView fitHeight="26.0" fitWidth="26.0" preserveRatio="true" smooth="true" styleClass="menu-icon">
                                    <image>
                                        <Image url="@../icons/bot.png"/>
                                    </image>
                                </ImageView>
                            </StackPane>

                            <VBox spacing="4" HBox.hgrow="ALWAYS">
                                <Label text="Play Bot" styleClass="row-title"/>
                                <Label text="Play White against the computer" styleClass="row-subtitle"/>
                            </VBox>

                            <StackPane styleClass="row-arrow-chip">
                                <ImageView fitHeight="20.0" fitWidth="20.0" preserveRatio="true" smooth="true" styleClass="row-arrow-icon">
                                    <image>
                                        <Image url="@../icons/chevron-right.png"/>
                                    </image>
                                </ImageView>
                            </StackPane>
                        </HBox>
                    </graphic>
                </Button>

                <Button maxWidth="Infinity"
                        onAction="#onCustomSetup"
                        styleClass="hex-action-row">
                    <graphic>
                        <HBox alignment="CENTER_LEFT" maxWidth="Infinity" spacing="22" styleClass="row-content">
                            <StackPane styleClass="row-icon-chip">
                                <ImageView fitHeight="26.0" fitWidth="26.0" preserveRatio="true" smooth="true" styleClass="menu-icon">
                                    <image>
                                        <Image url="@../icons/custom.png"/>
                                    </image>
                                </ImageView>
                            </StackPane>

                            <VBox spacing="4" HBox.hgrow="ALWAYS">
                                <Label text="Custom Setup" styleClass="row-title"/>
                                <Label text="Build a custom starting position" styleClass="row-subtitle"/>
                            </VBox>

                            <StackPane styleClass="row-arrow-chip">
                                <ImageView fitHeight="20.0" fitWidth="20.0" preserveRatio="true" smooth="true" styleClass="row-arrow-icon">
                                    <image>
                                        <Image url="@../icons/chevron-right.png"/>
                                    </image>
                                </ImageView>
                            </StackPane>
                        </HBox>
                    </graphic>
                </Button>

                <Region minHeight="1" styleClass="menu-divider"/>

                <Button maxWidth="Infinity"
                        onAction="#onBack"
                        styleClass="hex-action-row">
                    <graphic>
                        <HBox alignment="CENTER_LEFT" maxWidth="Infinity" spacing="22" styleClass="row-content">
                            <StackPane styleClass="row-icon-chip-danger">
                                <ImageView fitHeight="26.0" fitWidth="26.0" preserveRatio="true" smooth="true" styleClass="menu-icon-danger">
                                    <image>
                                        <Image url="@../icons/exit.png"/>
                                    </image>
                                </ImageView>
                            </StackPane>

                            <VBox spacing="4" HBox.hgrow="ALWAYS">
                                <Label text="Exit Game" styleClass="row-title"/>
                                <Label text="Return to GameBox" styleClass="row-subtitle"/>
                            </VBox>

                            <StackPane styleClass="row-arrow-chip">
                                <ImageView fitHeight="20.0" fitWidth="20.0" preserveRatio="true" smooth="true" styleClass="row-arrow-icon">
                                    <image>
                                        <Image url="@../icons/chevron-right.png"/>
                                    </image>
                                </ImageView>
                            </StackPane>
                        </HBox>
                    </graphic>
                </Button>
            </VBox>

            <Region VBox.vgrow="ALWAYS"/>
        </VBox>

        <VBox GridPane.columnIndex="1"
              GridPane.hgrow="ALWAYS"
              GridPane.vgrow="ALWAYS"
              maxHeight="Infinity"
              maxWidth="Infinity"
              spacing="14"
              styleClass="hex-network-panel">

            <VBox styleClass="menu-header">
                <Label text="N E T W O R K" styleClass="text-muted-caps"/>
                <Label text="Set players, host, or join LAN matches." styleClass="network-subtitle"/>
            </VBox>

            <VBox spacing="12" styleClass="side-section">
                <Label text="Players" styleClass="field-title"/>

                <GridPane styleClass="network-player-grid">
                    <columnConstraints>
                        <ColumnConstraints halignment="RIGHT" minWidth="88" prefWidth="88"/>
                        <ColumnConstraints hgrow="ALWAYS" minWidth="130"/>
                    </columnConstraints>

                    <Label text="White" graphicTextGap="6.0" styleClass="player-one-name" GridPane.columnIndex="0" GridPane.rowIndex="0">
                        <graphic>
                            <ImageView fitHeight="27.0" fitWidth="27.0" preserveRatio="true" smooth="true" styleClass="player-field-icon">
                                <image>
                                    <Image url="@../icons/player1.png"/>
                                </image>
                            </ImageView>
                        </graphic>
                    </Label>
                    <TextField fx:id="playerOneNameField"
                               text="The Old Monk"
                               promptText="The Old Monk"
                               GridPane.columnIndex="1"
                               GridPane.rowIndex="0">
                        <styleClass>
                            <String fx:value="player-name-field"/>
                            <String fx:value="player-one-name"/>
                        </styleClass>
                    </TextField>

                    <Label text="Black" graphicTextGap="6.0" styleClass="player-two-name" GridPane.columnIndex="0" GridPane.rowIndex="1">
                        <graphic>
                            <ImageView fitHeight="27.0" fitWidth="27.0" preserveRatio="true" smooth="true" styleClass="player-field-icon">
                                <image>
                                    <Image url="@../icons/player2.png"/>
                                </image>
                            </ImageView>
                        </graphic>
                    </Label>
                    <TextField fx:id="playerTwoNameField"
                               text="The Outer God"
                               promptText="The Outer God"
                               GridPane.columnIndex="1"
                               GridPane.rowIndex="1">
                        <styleClass>
                            <String fx:value="player-name-field"/>
                            <String fx:value="player-two-name"/>
                        </styleClass>
                    </TextField>
                </GridPane>
            </VBox>

            <VBox spacing="12" styleClass="network-section">
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Button onAction="#onHostLan" styleClass="network-host-icon-button">
                        <graphic>
                            <ImageView fitHeight="24.0" fitWidth="24.0" preserveRatio="true" smooth="true" styleClass="menu-icon">
                                <image>
                                    <Image url="@../icons/lan.png"/>
                                </image>
                            </ImageView>
                        </graphic>
                    </Button>
                    <Button fx:id="hostLanButton"
                            text="Host LAN Game"
                            maxWidth="Infinity"
                            HBox.hgrow="ALWAYS"
                            onAction="#onHostLan"
                            styleClass="network-host-button"/>
                </HBox>

                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Button text="Refresh" onAction="#onRefreshLan" maxWidth="Infinity"
                            styleClass="btn-secondary" HBox.hgrow="ALWAYS"/>
                    <Button fx:id="joinSelectedLanButton" text="Join Selected"
                            onAction="#onJoinSelectedLan" maxWidth="Infinity"
                            styleClass="btn-secondary" HBox.hgrow="ALWAYS"/>
                </HBox>

                <Button fx:id="cancelHostingButton"
                        text="Cancel Hosting"
                        onAction="#onCancelHost"
                        visible="false"
                        managed="false"
                        maxWidth="Infinity"
                        styleClass="btn-secondary"/>
            </VBox>

            <VBox spacing="8">
                <Label text="Available Games" styleClass="field-title"/>
                <ListView fx:id="lanGamesList" prefHeight="128" maxHeight="160" maxWidth="Infinity"
                          styleClass="match-list">
                    <placeholder>
                        <Label text="No LAN games found" styleClass="empty-list-label"/>
                    </placeholder>
                </ListView>
            </VBox>

            <Label fx:id="statusLabel" text="" wrapText="true" maxWidth="Infinity" styleClass="status-line"/>

            <Region VBox.vgrow="ALWAYS"/>

            <VBox spacing="8" styleClass="network-footer">
                <Label text="Chexsagon: Local, Bot, or LAN" styleClass="footer-title"/>
                <Label text="Glinski-style hex chess with synchronized network play."
                       wrapText="true"
                       styleClass="footer-line"/>
            </VBox>
        </VBox>
        </GridPane>
        </StackPane>
    </ScrollPane>
</StackPane>
