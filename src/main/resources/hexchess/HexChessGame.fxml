<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.canvas.Canvas?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane styleClass="hex-game-root"
            xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="seda_project.control_alt_defeat.gamebox.controller.hexchess.HexChessGameController">

    <stylesheets>
        <URL value="@HexChess.css"/>
    </stylesheets>

    <top>
        <VBox alignment="CENTER" styleClass="hex-game-header">
            <Label text="LIVE MATCH" styleClass="eyebrow"/>
            <Label text="Chexsagon" styleClass="title"/>
            <Label fx:id="modeLabel" styleClass="subtitle"/>
        </VBox>
    </top>

    <center>
        <HBox alignment="TOP_CENTER" spacing="18" styleClass="hex-stage" BorderPane.alignment="CENTER">
            <VBox minWidth="852"
                  prefWidth="852"
                  maxWidth="852"
                  styleClass="hex-board-panel board-surface">
                <HBox alignment="CENTER_LEFT" styleClass="board-header">
                    <VBox spacing="2">
                        <Label text="Board" styleClass="section-title"/>
                        <Label text="Promotion files are marked with arrows." styleClass="section-copy"/>
                    </VBox>
                </HBox>
                <StackPane minWidth="820"
                           minHeight="650"
                           prefWidth="820"
                           prefHeight="650"
                           styleClass="canvas-frame">
                    <Canvas fx:id="boardCanvas" width="820" height="650"/>
                </StackPane>
            </VBox>

            <VBox minWidth="288" prefWidth="304" maxWidth="320" styleClass="hex-side-panel">
                <VBox styleClass="sidebar-section hero-section">
                    <Label text="Turn" styleClass="panel-label"/>
                    <Label fx:id="turnLabel" styleClass="turn-display"/>
                    <Label fx:id="statusLabel" wrapText="true" minHeight="52" styleClass="status-box"/>
                </VBox>

                <Separator/>

                <VBox styleClass="sidebar-section">
                    <Label text="Position" styleClass="panel-label"/>
                    <Label fx:id="scoreLabel" styleClass="stat-line"/>
                    <Label fx:id="lastMoveLabel" wrapText="true" styleClass="stat-line"/>
                    <Label fx:id="drawOfferLabel" wrapText="true" styleClass="stat-line accent-line"/>
                </VBox>

                <Separator/>

                <VBox styleClass="sidebar-section">
                    <Label text="Actions" styleClass="panel-label"/>
                    <HBox styleClass="button-row">
                        <Button text="Offer Draw" onAction="#onOfferDraw" maxWidth="Infinity"
                                styleClass="btn-outline" HBox.hgrow="ALWAYS"/>
                        <Button text="Resign" onAction="#onResign" maxWidth="Infinity"
                                styleClass="btn-danger" HBox.hgrow="ALWAYS"/>
                    </HBox>

                    <HBox styleClass="button-row">
                        <Button fx:id="acceptDrawButton" text="Accept" onAction="#onAcceptDraw"
                                visible="false" managed="false" maxWidth="Infinity"
                                styleClass="btn-primary" HBox.hgrow="ALWAYS"/>
                        <Button fx:id="declineDrawButton" text="Decline" onAction="#onDeclineDraw"
                                visible="false" managed="false" maxWidth="Infinity"
                                styleClass="btn-outline" HBox.hgrow="ALWAYS"/>
                    </HBox>

                    <HBox styleClass="button-row">
                        <Button text="Restart" onAction="#onRestart" maxWidth="Infinity"
                                styleClass="btn-outline" HBox.hgrow="ALWAYS"/>
                        <Button text="Menu" onAction="#onBackToMenu" maxWidth="Infinity"
                                styleClass="btn-primary" HBox.hgrow="ALWAYS"/>
                    </HBox>
                </VBox>
            </VBox>
        </HBox>
    </center>

    <padding>
        <Insets top="18" right="24" bottom="18" left="24"/>
    </padding>
</BorderPane>
