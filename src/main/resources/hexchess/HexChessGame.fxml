<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane styleClass="hex-game-root"
            xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="seda_project.control_alt_defeat.gamebox.controller.hexchess.HexChessGameController">

    <stylesheets>
        <URL value="@HexChess.css"/>
    </stylesheets>

    <top>
        <VBox alignment="CENTER" styleClass="hex-game-header">
            <Label text="Hexagon Chess" styleClass="title"/>
            <Label fx:id="modeLabel" text="" styleClass="subtitle"/>
        </VBox>
    </top>

    <center>
        <HBox alignment="CENTER" spacing="18" BorderPane.alignment="CENTER">
            <Pane fx:id="boardPane"
                  minWidth="820"
                  minHeight="650"
                  prefWidth="820"
                  prefHeight="650"
                  styleClass="hex-board-panel"/>

            <VBox alignment="TOP_LEFT" minWidth="260" prefWidth="280" maxWidth="300" styleClass="hex-side-panel">
                <Label fx:id="turnLabel" text="" styleClass="section-title"/>
                <Label fx:id="statusLabel" text="" wrapText="true" styleClass="status-line"/>
                <Separator/>
                <Label fx:id="scoreLabel" text="" styleClass="status-line"/>
                <Label fx:id="lastMoveLabel" text="" wrapText="true" styleClass="status-line"/>
                <Label fx:id="drawOfferLabel" text="" wrapText="true" styleClass="status-line"/>

                <HBox styleClass="button-row">
                    <Button text="Offer Draw" onAction="#onOfferDraw" styleClass="btn-outline"/>
                    <Button text="Resign" onAction="#onResign" styleClass="btn-outline"/>
                </HBox>

                <HBox styleClass="button-row">
                    <Button fx:id="acceptDrawButton" text="Accept" onAction="#onAcceptDraw"
                            visible="false" managed="false" styleClass="btn-primary"/>
                    <Button fx:id="declineDrawButton" text="Decline" onAction="#onDeclineDraw"
                            visible="false" managed="false" styleClass="btn-outline"/>
                </HBox>

                <Separator/>

                <HBox styleClass="button-row">
                    <Button text="Restart" onAction="#onRestart" styleClass="btn-outline"/>
                    <Button text="Menu" onAction="#onBackToMenu" styleClass="btn-primary"/>
                </HBox>
            </VBox>
        </HBox>
    </center>

    <padding>
        <Insets top="18" right="24" bottom="18" left="24"/>
    </padding>
</BorderPane>
