<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.scene.canvas.Canvas?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane styleClass="hex-game-root"
            xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="seda_project.control_alt_defeat.gamebox.controller.hexchess.HexChessGameController">

    <stylesheets>
        <URL value="@HexChess.css"/>
    </stylesheets>

    <center>
        <ScrollPane fitToHeight="true"
                    fitToWidth="true"
                    hbarPolicy="AS_NEEDED"
                    vbarPolicy="AS_NEEDED"
                    styleClass="app-scroll">
        <GridPane minHeight="640"
                  minWidth="0"
                  maxHeight="Infinity"
                  maxWidth="Infinity"
                  styleClass="hex-game-main">
            <columnConstraints>
                <ColumnConstraints hgrow="ALWAYS" percentWidth="70"/>
                <ColumnConstraints hgrow="ALWAYS" percentWidth="30"/>
            </columnConstraints>

            <StackPane fx:id="boardZone"
                       GridPane.columnIndex="0"
                       GridPane.hgrow="ALWAYS"
                       GridPane.vgrow="ALWAYS"
                       maxHeight="Infinity"
                       maxWidth="Infinity"
                       styleClass="hex-board-zone">
                <Canvas fx:id="boardCanvas" width="720" height="620"/>
            </StackPane>

            <ScrollPane GridPane.columnIndex="1"
                        GridPane.hgrow="ALWAYS"
                        GridPane.vgrow="ALWAYS"
                        fitToHeight="true"
                        fitToWidth="true"
                        hbarPolicy="NEVER"
                        vbarPolicy="AS_NEEDED"
                        maxHeight="Infinity"
                        maxWidth="Infinity"
                        styleClass="app-scroll">
                <VBox maxHeight="Infinity"
                      maxWidth="Infinity"
                      spacing="18"
                      styleClass="hex-game-info-panel">

                <VBox styleClass="hex-game-header">
                    <Label text="Live Match" styleClass="eyebrow"/>
                    <Label text="Chexsagon" styleClass="title"/>
                    <Label fx:id="modeLabel" styleClass="subtitle"/>
                </VBox>

                <Separator/>

                <VBox styleClass="sidebar-section">
                    <Label text="Turn" styleClass="panel-label"/>
                    <Label fx:id="turnLabel" styleClass="turn-display"/>
                    <Label fx:id="statusLabel" wrapText="true" minHeight="52" styleClass="status-box"/>
                </VBox>

                <Separator/>

                <VBox styleClass="sidebar-section">
                    <Label text="Points" styleClass="panel-label"/>
                    <Label fx:id="scoreLabel" styleClass="stat-line"/>
                    <Label fx:id="lastMoveLabel" wrapText="true" styleClass="stat-line"/>
                    <Label fx:id="drawOfferLabel" wrapText="true" styleClass="stat-line"/>
                </VBox>

                <Separator/>

                <Region VBox.vgrow="ALWAYS"/>

                <VBox styleClass="sidebar-section hex-match-actions">
                    <Label text="Actions" styleClass="panel-label"/>
                    <HBox styleClass="button-row">
                        <Button fx:id="offerDrawButton" text="Offer Draw" onAction="#onOfferDraw" maxWidth="Infinity"
                                styleClass="hex-control-button" HBox.hgrow="ALWAYS"/>
                        <Button fx:id="resignButton" text="Resign" onAction="#onResign" maxWidth="Infinity"
                                styleClass="hex-control-button hex-control-danger" HBox.hgrow="ALWAYS"/>
                    </HBox>

                    <HBox styleClass="button-row">
                        <Button fx:id="acceptDrawButton" text="Accept" onAction="#onAcceptDraw"
                                visible="false" managed="false" maxWidth="Infinity"
                                styleClass="hex-control-button" HBox.hgrow="ALWAYS"/>
                        <Button fx:id="declineDrawButton" text="Decline" onAction="#onDeclineDraw"
                                visible="false" managed="false" maxWidth="Infinity"
                                styleClass="hex-control-button" HBox.hgrow="ALWAYS"/>
                    </HBox>

                    <HBox styleClass="button-row">
                        <Button fx:id="restartButton" text="Restart" onAction="#onRestart" maxWidth="Infinity"
                                styleClass="hex-control-button" HBox.hgrow="ALWAYS"/>
                        <Button text="Back to Menu" onAction="#onBackToMenu" maxWidth="Infinity"
                                styleClass="hex-control-button" HBox.hgrow="ALWAYS"/>
                    </HBox>
                </VBox>
                </VBox>
            </ScrollPane>
        </GridPane>
        </ScrollPane>
    </center>
</BorderPane>
