<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import java.net.URL?>
<?import javafx.scene.canvas.Canvas?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane styleClass="hex-game-root"
            xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="seda_project.control_alt_defeat.gamebox.controller.hexchess.HexChessGameController">

    <stylesheets>
        <URL value="@HexChess.css"/>
    </stylesheets>

    <center>
        <GridPane maxHeight="Infinity"
                  maxWidth="Infinity"
                  styleClass="hex-game-main">
            <columnConstraints>
                <ColumnConstraints hgrow="ALWAYS" percentWidth="65"/>
                <ColumnConstraints hgrow="ALWAYS" percentWidth="35"/>
            </columnConstraints>

            <StackPane fx:id="boardZone"
                       GridPane.columnIndex="0"
                       GridPane.hgrow="ALWAYS"
                       GridPane.vgrow="ALWAYS"
                       maxHeight="Infinity"
                       maxWidth="Infinity"
                       styleClass="hex-board-zone">
                <Canvas fx:id="boardCanvas" width="1122" height="952"/>
            </StackPane>

            <VBox GridPane.columnIndex="1"
                  GridPane.hgrow="ALWAYS"
                  GridPane.vgrow="ALWAYS"
                  maxHeight="Infinity"
                  maxWidth="Infinity"
                  spacing="18"
                  styleClass="hex-game-info-panel">

                <VBox styleClass="hex-game-header">
                    <Label text="Live Match" styleClass="eyebrow"/>
                    <Label text="Chexsagon" styleClass="title"/>
                    <Label fx:id="modeLabel" styleClass="subtitle"/>
                </VBox>

                <Separator/>

                <VBox styleClass="sidebar-section">
                    <Label text="Turn" styleClass="panel-label"/>
                    <Label fx:id="turnLabel" styleClass="turn-display"/>
                    <Label fx:id="statusLabel" wrapText="true" minHeight="52" styleClass="status-box"/>
                </VBox>

                <Separator/>

                <VBox styleClass="sidebar-section">
                    <Label text="Points" styleClass="panel-label"/>
                    <Label fx:id="scoreLabel" styleClass="stat-line"/>
                    <Label fx:id="lastMoveLabel" wrapText="true" styleClass="stat-line"/>
                    <Label fx:id="drawOfferLabel" wrapText="true">
                        <styleClass>
                            <String fx:value="stat-line"/>
                            <String fx:value="accent-line"/>
                        </styleClass>
                    </Label>
                </VBox>

                <Separator/>

                <VBox styleClass="sidebar-section">
                    <Label text="Actions" styleClass="panel-label"/>
                    <HBox styleClass="button-row">
                        <Button fx:id="offerDrawButton" text="Offer Draw" onAction="#onOfferDraw" maxWidth="Infinity"
                                styleClass="btn-outline" HBox.hgrow="ALWAYS"/>
                        <Button fx:id="resignButton" text="Resign" onAction="#onResign" maxWidth="Infinity"
                                styleClass="btn-danger" HBox.hgrow="ALWAYS"/>
                    </HBox>

                    <HBox styleClass="button-row">
                        <Button fx:id="acceptDrawButton" text="Accept" onAction="#onAcceptDraw"
                                visible="false" managed="false" maxWidth="Infinity"
                                styleClass="btn-primary" HBox.hgrow="ALWAYS"/>
                        <Button fx:id="declineDrawButton" text="Decline" onAction="#onDeclineDraw"
                                visible="false" managed="false" maxWidth="Infinity"
                                styleClass="btn-outline" HBox.hgrow="ALWAYS"/>
                    </HBox>

                    <HBox styleClass="button-row">
                        <Button fx:id="restartButton" text="Restart" onAction="#onRestart" maxWidth="Infinity"
                                styleClass="btn-outline" HBox.hgrow="ALWAYS"/>
                        <Button text="Menu" onAction="#onBackToMenu" maxWidth="Infinity"
                                styleClass="btn-primary" HBox.hgrow="ALWAYS"/>
                    </HBox>
                </VBox>

                <Region VBox.vgrow="ALWAYS"/>
            </VBox>
        </GridPane>
    </center>
</BorderPane>
