<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import java.net.URL?>
<?import javafx.scene.canvas.Canvas?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane styleClass="hex-game-root"
            xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="seda_project.control_alt_defeat.gamebox.controller.hexchess.HexChessGameController">

    <stylesheets>
        <URL value="@HexChess.css"/>
    </stylesheets>

    <center>
        <ScrollPane fitToHeight="true"
                    fitToWidth="true"
                    hbarPolicy="AS_NEEDED"
                    vbarPolicy="AS_NEEDED"
                    styleClass="app-scroll">
        <GridPane fx:id="gameMain"
                  minHeight="480"
                  minWidth="0"
                  maxHeight="Infinity"
                  maxWidth="Infinity"
                  styleClass="hex-game-main">
            <columnConstraints>
                <ColumnConstraints hgrow="ALWAYS" percentWidth="70"/>
                <ColumnConstraints hgrow="ALWAYS" percentWidth="30"/>
            </columnConstraints>

            <StackPane fx:id="boardZone"
                       GridPane.columnIndex="0"
                       GridPane.hgrow="ALWAYS"
                       GridPane.vgrow="ALWAYS"
                       maxHeight="Infinity"
                       maxWidth="Infinity"
                       styleClass="hex-board-zone">
                <Canvas fx:id="boardCanvas"/>

                <VBox fx:id="boardGuideSection"
                      visible="false"
                      managed="false"
                      mouseTransparent="true"
                      maxWidth="220"
                      spacing="7"
                      StackPane.alignment="CENTER_LEFT"
                      styleClass="board-guide-card">
                    <Label text="Board guide" styleClass="board-guide-title"/>
                    <Label text="Select a piece, then choose a marker."
                           maxWidth="Infinity"
                           wrapText="true"
                           styleClass="board-guide-copy"/>
                    <HBox alignment="CENTER_LEFT" spacing="8">
                        <Label text="●" styleClass="board-guide-legal"/>
                        <Label text="Legal move" styleClass="board-guide-copy"/>
                    </HBox>
                    <HBox alignment="CENTER_LEFT" spacing="8">
                        <Label text="⬡" styleClass="board-guide-last-move"/>
                        <Label text="Last move" styleClass="board-guide-copy"/>
                    </HBox>
                    <HBox alignment="CENTER_LEFT" spacing="8">
                        <Label text="⬡" styleClass="board-guide-check"/>
                        <Label text="King in check" styleClass="board-guide-copy"/>
                    </HBox>
                    <HBox alignment="CENTER_LEFT" spacing="8">
                        <Label text="★" styleClass="board-guide-promotion"/>
                        <Label text="Promotion square" styleClass="board-guide-copy"/>
                    </HBox>
                </VBox>
            </StackPane>

            <ScrollPane fx:id="infoScrollPane"
                        GridPane.columnIndex="1"
                        GridPane.hgrow="ALWAYS"
                        GridPane.vgrow="ALWAYS"
                        fitToHeight="true"
                        fitToWidth="true"
                        hbarPolicy="NEVER"
                        vbarPolicy="AS_NEEDED"
                        maxHeight="Infinity"
                        maxWidth="Infinity"
                        styleClass="app-scroll">
                <VBox maxHeight="Infinity"
                      maxWidth="Infinity"
                      spacing="14"
                      styleClass="hex-game-info-panel">

                <VBox styleClass="hex-game-header">
                    <Label text="Live Match" styleClass="eyebrow"/>
                    <Label text="Chexsagon" styleClass="title"/>
                    <Label fx:id="modeLabel" maxWidth="Infinity" wrapText="true" styleClass="subtitle"/>
                </VBox>

                <Separator/>

                <VBox styleClass="sidebar-section">
                    <Label text="Turn" styleClass="panel-label"/>
                    <Label fx:id="turnLabel" maxWidth="Infinity" wrapText="true" styleClass="turn-display"/>
                    <Label fx:id="turnDetailLabel" maxWidth="Infinity" wrapText="true" styleClass="turn-detail"/>
                    <Label fx:id="statusLabel" maxWidth="Infinity" wrapText="true"
                           styleClass="status-box"/>
                </VBox>

                <Separator/>

                <VBox styleClass="sidebar-section">
                    <Label text="Points" styleClass="panel-label"/>
                    <Label fx:id="scoreLabel" styleClass="stat-line"/>
                    <Label fx:id="lastMoveLabel" wrapText="true" styleClass="stat-line"/>
                </VBox>

                <Separator/>

                <Region VBox.vgrow="ALWAYS"/>

                <VBox spacing="10">
                    <styleClass>
                        <String fx:value="sidebar-section"/>
                        <String fx:value="hex-match-actions"/>
                    </styleClass>
                    <Label text="Actions" styleClass="panel-label"/>
                    <Button fx:id="offerDrawButton" text="Offer Draw" onAction="#onOfferDraw" maxWidth="Infinity"
                            styleClass="hex-control-button"/>
                    <Button fx:id="resignButton" text="Resign" onAction="#onResign" maxWidth="Infinity">
                        <styleClass>
                            <String fx:value="hex-control-button"/>
                            <String fx:value="hex-control-danger"/>
                        </styleClass>
                    </Button>
                    <Button fx:id="acceptDrawButton" text="Accept" onAction="#onAcceptDraw"
                            visible="false" managed="false" maxWidth="Infinity"
                            styleClass="hex-control-button"/>
                    <Button fx:id="declineDrawButton" text="Decline" onAction="#onDeclineDraw"
                            visible="false" managed="false" maxWidth="Infinity"
                            styleClass="hex-control-button"/>
                    <Button fx:id="restartButton" text="Restart" onAction="#onRestart" maxWidth="Infinity"
                            styleClass="hex-control-button"/>
                    <Button text="Back to Menu" onAction="#onBackToMenu" maxWidth="Infinity"
                            styleClass="hex-control-button"/>
                </VBox>
                </VBox>
            </ScrollPane>
        </GridPane>
        </ScrollPane>
    </center>
</BorderPane>
