<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.canvas.Canvas?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane styleClass="hex-game-root"
            xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="seda_project.control_alt_defeat.gamebox.controller.hexchess.HexChessSetupController">

    <stylesheets>
        <URL value="@HexChess.css"/>
    </stylesheets>

    <center>
        <ScrollPane fitToHeight="true"
                    fitToWidth="true"
                    hbarPolicy="AS_NEEDED"
                    vbarPolicy="AS_NEEDED"
                    styleClass="app-scroll"
                    BorderPane.alignment="CENTER">
            <VBox minHeight="580"
                  maxWidth="Infinity"
                  spacing="10"
                  styleClass="hex-setup-content">
            <VBox alignment="CENTER" styleClass="hex-setup-header">
                <Label text="Custom Position Builder" styleClass="title"/>
                <Label text="Build a valid Chexsagon starting position" styleClass="subtitle"/>
            </VBox>
            <GridPane fx:id="setupMain"
                      alignment="TOP_CENTER"
                      hgap="18"
                      minHeight="480"
                      minWidth="0"
                      VBox.vgrow="ALWAYS"
                      styleClass="hex-stage">
            <columnConstraints>
                <ColumnConstraints hgrow="ALWAYS" percentWidth="60"/>
                <ColumnConstraints hgrow="ALWAYS" percentWidth="40"/>
            </columnConstraints>

            <VBox fx:id="boardEditorPanel"
                  GridPane.columnIndex="0"
                  GridPane.hgrow="ALWAYS"
                  GridPane.vgrow="ALWAYS"
                  minWidth="0"
                  maxWidth="Infinity">
                <styleClass>
                    <String fx:value="hex-board-panel"/>
                    <String fx:value="board-surface"/>
                </styleClass>
                <HBox alignment="CENTER_LEFT" styleClass="board-header">
                    <VBox spacing="2">
                        <Label text="Board Editor" styleClass="section-title"/>
                        <Label text="Click a cell to place the selected piece." styleClass="section-copy"/>
                    </VBox>
                </HBox>
                <StackPane fx:id="canvasFrame"
                           minWidth="0"
                           minHeight="0"
                           maxWidth="Infinity"
                           maxHeight="Infinity"
                           styleClass="canvas-frame">
                    <Canvas fx:id="boardCanvas"/>
                </StackPane>
            </VBox>

            <VBox GridPane.columnIndex="1"
                  GridPane.hgrow="ALWAYS"
                  GridPane.vgrow="ALWAYS"
                  minWidth="0"
                  maxWidth="Infinity"
                  styleClass="hex-side-panel">
                <VBox styleClass="sidebar-section">
                    <Label text="Players" styleClass="panel-label"/>
                    <GridPane styleClass="hex-form-grid">
                        <columnConstraints>
                            <ColumnConstraints halignment="RIGHT" minWidth="82" prefWidth="82"/>
                            <ColumnConstraints hgrow="ALWAYS" minWidth="130" prefWidth="162"/>
                        </columnConstraints>
                        <Label text="White" graphicTextGap="6.0" styleClass="player-one-name" GridPane.columnIndex="0" GridPane.rowIndex="0">
                            <graphic>
                                <ImageView fitHeight="27.0" fitWidth="27.0" preserveRatio="true" smooth="true" styleClass="player-field-icon">
                                    <image>
                                        <Image url="@../icons/player1.png"/>
                                    </image>
                                </ImageView>
                            </graphic>
                        </Label>
                        <TextField fx:id="playerOneNameField"
                                   text="The Old Monk"
                                   promptText="The Old Monk"
                                   GridPane.columnIndex="1"
                                   GridPane.rowIndex="0">
                            <styleClass>
                                <String fx:value="player-name-field"/>
                                <String fx:value="player-one-name"/>
                            </styleClass>
                        </TextField>
                        <Label text="Black" graphicTextGap="6.0" styleClass="player-two-name" GridPane.columnIndex="0" GridPane.rowIndex="1">
                            <graphic>
                                <ImageView fitHeight="27.0" fitWidth="27.0" preserveRatio="true" smooth="true" styleClass="player-field-icon">
                                    <image>
                                        <Image url="@../icons/player2.png"/>
                                    </image>
                                </ImageView>
                            </graphic>
                        </Label>
                        <TextField fx:id="playerTwoNameField"
                                   text="The Outer God"
                                   promptText="The Outer God"
                                   GridPane.columnIndex="1"
                                   GridPane.rowIndex="1">
                            <styleClass>
                                <String fx:value="player-name-field"/>
                                <String fx:value="player-two-name"/>
                            </styleClass>
                        </TextField>
                    </GridPane>
                </VBox>

                <Separator/>

                <VBox styleClass="sidebar-section">
                    <Label text="Placement" styleClass="panel-label"/>
                    <ComboBox fx:id="colorChoiceBox" maxWidth="Infinity"/>
                    <ComboBox fx:id="typeChoiceBox" maxWidth="Infinity"/>
                    <Label fx:id="selectedLabel" text="Selected: none" wrapText="true" styleClass="stat-line"/>
                    <Button text="Remove Piece" onAction="#onRemovePiece" maxWidth="Infinity" styleClass="btn-outline"/>
                </VBox>

                <Separator/>

                <VBox styleClass="sidebar-section">
                    <Label text="Position State" styleClass="panel-label"/>
                    <ComboBox fx:id="turnChoiceBox" maxWidth="Infinity"/>
                    <HBox styleClass="button-row">
                        <Button text="Standard" onAction="#onLoadStandard" maxWidth="Infinity"
                                styleClass="btn-outline" HBox.hgrow="ALWAYS"/>
                        <Button text="Clear" onAction="#onClearBoard" maxWidth="Infinity"
                                styleClass="btn-danger" HBox.hgrow="ALWAYS"/>
                    </HBox>
                    <Label fx:id="validationLabel" wrapText="true" minHeight="56" styleClass="status-box"/>
                </VBox>

                <Separator/>

                <HBox styleClass="button-row">
                    <Button text="Back" onAction="#onBack" maxWidth="Infinity"
                            styleClass="btn-outline" HBox.hgrow="ALWAYS"/>
                    <Button fx:id="startButton" text="Start" onAction="#onStart" maxWidth="Infinity"
                            HBox.hgrow="ALWAYS">
                        <styleClass>
                            <String fx:value="btn-primary"/>
                            <String fx:value="game-start-button"/>
                        </styleClass>
                    </Button>
                </HBox>
            </VBox>
            </GridPane>
            </VBox>
        </ScrollPane>
    </center>

    <padding>
        <Insets top="10" right="24" bottom="10" left="24"/>
    </padding>
</BorderPane>
