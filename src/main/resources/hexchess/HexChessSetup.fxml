<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.canvas.Canvas?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.effect.GaussianBlur?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane fx:id="hexSetupRoot"
           styleClass="hex-game-root"
           xmlns="http://javafx.com/javafx"
           xmlns:fx="http://javafx.com/fxml"
           fx:controller="seda_project.control_alt_defeat.gamebox.controller.hexchess.HexChessSetupController">

    <stylesheets>
        <URL value="@HexChess.css"/>
    </stylesheets>

    <ImageView fitHeight="${hexSetupRoot.height}"
               fitWidth="${hexSetupRoot.width}"
               mouseTransparent="true"
               preserveRatio="false"
               smooth="true">
        <image>
            <Image url="@../images/game-choice-background.png"/>
        </image>
        <effect>
            <GaussianBlur radius="7.0"/>
        </effect>
    </ImageView>

    <Region mouseTransparent="true" styleClass="game-background-overlay"/>

    <BorderPane styleClass="game-screen-content">
        <top>
        <VBox alignment="CENTER" styleClass="hex-game-header">
            <Label text="POSITION BUILDER" styleClass="eyebrow"/>
            <Label text="Custom Position" styleClass="title"/>
            <Label text="Build a valid Chexsagon starting position" styleClass="subtitle"/>
        </VBox>
        </top>

        <center>
        <ScrollPane fitToHeight="true"
                    fitToWidth="true"
                    hbarPolicy="AS_NEEDED"
                    vbarPolicy="AS_NEEDED"
                    styleClass="app-scroll"
                    BorderPane.alignment="CENTER">
            <GridPane alignment="TOP_CENTER"
                      hgap="18"
                      minHeight="0"
                      minWidth="0"
                      styleClass="hex-stage">
            <columnConstraints>
                <ColumnConstraints hgrow="ALWAYS" percentWidth="60"/>
                <ColumnConstraints hgrow="ALWAYS" percentWidth="40"/>
            </columnConstraints>

            <VBox GridPane.columnIndex="0"
                  GridPane.hgrow="ALWAYS"
                  GridPane.vgrow="ALWAYS"
                  minWidth="0"
                  maxWidth="Infinity">
                <styleClass>
                    <String fx:value="hex-board-panel"/>
                    <String fx:value="board-surface"/>
                </styleClass>
                <HBox alignment="CENTER_LEFT" styleClass="board-header">
                    <VBox spacing="2">
                        <Label text="Board Editor" styleClass="section-title"/>
                        <Label text="Click a cell to place the selected piece." styleClass="section-copy"/>
                    </VBox>
                </HBox>
                <StackPane fx:id="canvasFrame"
                           minWidth="0"
                           minHeight="0"
                           maxWidth="Infinity"
                           maxHeight="Infinity"
                           styleClass="canvas-frame">
                    <Canvas fx:id="boardCanvas"/>
                </StackPane>
            </VBox>

            <VBox GridPane.columnIndex="1"
                  GridPane.hgrow="ALWAYS"
                  GridPane.vgrow="ALWAYS"
                  minWidth="0"
                  maxWidth="Infinity"
                  styleClass="hex-side-panel">
                <VBox styleClass="sidebar-section">
                    <Label text="Players" styleClass="panel-label"/>
                    <GridPane styleClass="hex-form-grid">
                        <columnConstraints>
                            <ColumnConstraints halignment="RIGHT" minWidth="58" prefWidth="58"/>
                            <ColumnConstraints hgrow="ALWAYS" minWidth="170" prefWidth="186"/>
                        </columnConstraints>
                        <Label text="White" styleClass="player-one-name" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                        <TextField fx:id="playerOneNameField"
                                   text="The Old Monk"
                                   promptText="The Old Monk"
                                   styleClass="player-name-field player-one-name"
                                   GridPane.columnIndex="1"
                                   GridPane.rowIndex="0"/>
                        <Label text="Black" styleClass="player-two-name" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                        <TextField fx:id="playerTwoNameField"
                                   text="The Outer God"
                                   promptText="The Outer God"
                                   styleClass="player-name-field player-two-name"
                                   GridPane.columnIndex="1"
                                   GridPane.rowIndex="1"/>
                    </GridPane>
                </VBox>

                <VBox styleClass="sidebar-section">
                    <Label text="Placement" styleClass="panel-label"/>
                    <ComboBox fx:id="colorChoiceBox" maxWidth="Infinity"/>
                    <ComboBox fx:id="typeChoiceBox" maxWidth="Infinity"/>
                    <Label fx:id="selectedLabel" text="Selected: none" wrapText="true" styleClass="stat-line"/>
                    <Button text="Remove Piece" onAction="#onRemovePiece" maxWidth="Infinity" styleClass="btn-outline"/>
                </VBox>

                <VBox styleClass="sidebar-section">
                    <Label text="Position State" styleClass="panel-label"/>
                    <ComboBox fx:id="turnChoiceBox" maxWidth="Infinity"/>
                    <HBox styleClass="button-row">
                        <Button text="Standard" onAction="#onLoadStandard" maxWidth="Infinity"
                                styleClass="btn-outline" HBox.hgrow="ALWAYS"/>
                        <Button text="Clear" onAction="#onClearBoard" maxWidth="Infinity"
                                styleClass="btn-danger" HBox.hgrow="ALWAYS"/>
                    </HBox>
                    <Label fx:id="validationLabel" wrapText="true" minHeight="56" maxWidth="Infinity" styleClass="status-box"/>
                </VBox>

                <HBox styleClass="button-row">
                    <Button text="Back" onAction="#onBack" maxWidth="Infinity"
                            styleClass="btn-outline" HBox.hgrow="ALWAYS"/>
                    <Button fx:id="startButton" text="Start" onAction="#onStart" maxWidth="Infinity"
                            styleClass="btn-primary" HBox.hgrow="ALWAYS"/>
                </HBox>
            </VBox>
            </GridPane>
        </ScrollPane>
        </center>

        <padding>
            <Insets top="18" right="24" bottom="18" left="24"/>
        </padding>
    </BorderPane>
</StackPane>
