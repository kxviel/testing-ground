<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane fx:id="root"
           prefHeight="720.0"
           prefWidth="1080.0"
           focusTraversable="true"
           styleClass="game-choice-root"
           xmlns="http://javafx.com/javafx"
           xmlns:fx="http://javafx.com/fxml"
           fx:controller="seda_project.control_alt_defeat.gamebox.controller.GameChoice">

    <stylesheets>
        <URL value="@GameChoice.css"/>
    </stylesheets>

    <ScrollPane fitToHeight="true"
                fitToWidth="true"
                hbarPolicy="AS_NEEDED"
                vbarPolicy="AS_NEEDED"
                styleClass="app-scroll">
        <StackPane minHeight="680"
                   minWidth="960"
                   maxHeight="Infinity"
                   maxWidth="Infinity"
                   alignment="CENTER"
                   styleClass="game-choice-main">
            <StackPane prefHeight="620"
                       prefWidth="620"
                       maxHeight="620"
                       maxWidth="620"
                       styleClass="game-choice-frame">
                <VBox alignment="TOP_CENTER"
                      prefWidth="536"
                      maxWidth="536"
                      spacing="46"
                      styleClass="game-choices">

                    <VBox alignment="CENTER" spacing="17" styleClass="game-choice-header">
                        <Label text="G A M E B O X" styleClass="game-choice-eyebrow"/>
                        <Label text="Zero Runtime Warranty" styleClass="game-choice-title"/>
                    </VBox>

                    <VBox spacing="32" styleClass="game-list">
                        <Button maxWidth="Infinity" onAction="#playMemory" styleClass="game-row">
                            <graphic>
                                <HBox alignment="CENTER_LEFT" maxWidth="Infinity" spacing="19" styleClass="row-content">
                                    <StackPane styleClass="icon-chip">
                                        <ImageView fitHeight="34.0" fitWidth="34.0" preserveRatio="true" styleClass="game-icon">
                                            <image>
                                                <Image url="@icons/memory-card-icon.png"/>
                                            </image>
                                        </ImageView>
                                    </StackPane>
                                    <VBox spacing="3" HBox.hgrow="ALWAYS">
                                        <Label maxWidth="Infinity" text="EarlyAlzheimers" styleClass="row-title"/>
                                        <Label maxWidth="Infinity" text="A memory matching challenge" styleClass="row-subtitle"/>
                                    </VBox>
                                    <StackPane styleClass="row-arrow-chip">
                                        <ImageView fitHeight="20.0" fitWidth="20.0" preserveRatio="true" styleClass="row-chevron-icon">
                                            <image>
                                                <Image url="@icons/icons8-chevron-right-96.png"/>
                                            </image>
                                        </ImageView>
                                    </StackPane>
                                </HBox>
                            </graphic>
                        </Button>

                        <Button maxWidth="Infinity" onAction="#playTetris" styleClass="game-row">
                            <graphic>
                                <HBox alignment="CENTER_LEFT" maxWidth="Infinity" spacing="19" styleClass="row-content">
                                    <StackPane styleClass="icon-chip">
                                        <ImageView fitHeight="34.0" fitWidth="34.0" preserveRatio="true" styleClass="game-icon">
                                            <image>
                                                <Image url="@icons/tetris-icon.png"/>
                                            </image>
                                        </ImageView>
                                    </StackPane>
                                    <VBox spacing="3" HBox.hgrow="ALWAYS">
                                        <Label maxWidth="Infinity" text="Zetris" styleClass="row-title"/>
                                        <Label maxWidth="Infinity" text="Stack the falling blocks" styleClass="row-subtitle"/>
                                    </VBox>
                                    <StackPane styleClass="row-arrow-chip">
                                        <ImageView fitHeight="20.0" fitWidth="20.0" preserveRatio="true" styleClass="row-chevron-icon">
                                            <image>
                                                <Image url="@icons/icons8-chevron-right-96.png"/>
                                            </image>
                                        </ImageView>
                                    </StackPane>
                                </HBox>
                            </graphic>
                        </Button>

                        <Button maxWidth="Infinity" onAction="#playHexChess" styleClass="game-row">
                            <graphic>
                                <HBox alignment="CENTER_LEFT" maxWidth="Infinity" spacing="19" styleClass="row-content">
                                    <StackPane styleClass="icon-chip">
                                        <ImageView fitHeight="34.0" fitWidth="34.0" preserveRatio="true" styleClass="game-icon">
                                            <image>
                                                <Image url="@icons/chess-icon.png"/>
                                            </image>
                                        </ImageView>
                                    </StackPane>
                                    <VBox spacing="3" HBox.hgrow="ALWAYS">
                                        <Label maxWidth="Infinity" text="Chexsagon" styleClass="row-title"/>
                                        <Label maxWidth="Infinity" text="Hex chess with a twist" styleClass="row-subtitle"/>
                                    </VBox>
                                    <StackPane styleClass="row-arrow-chip">
                                        <ImageView fitHeight="20.0" fitWidth="20.0" preserveRatio="true" styleClass="row-chevron-icon">
                                            <image>
                                                <Image url="@icons/icons8-chevron-right-96.png"/>
                                            </image>
                                        </ImageView>
                                    </StackPane>
                                </HBox>
                            </graphic>
                        </Button>

                        <Region maxHeight="1.0" maxWidth="Infinity" minHeight="1.0" prefHeight="1.0" styleClass="game-choice-divider"/>

                        <Button id="exit-row" maxWidth="Infinity" onAction="#exit" styleClass="game-row">
                            <graphic>
                                <HBox alignment="CENTER_LEFT" maxWidth="Infinity" spacing="19" styleClass="row-content">
                                    <StackPane styleClass="icon-chip">
                                        <ImageView fitHeight="34.0" fitWidth="34.0" preserveRatio="true" styleClass="game-icon">
                                            <image>
                                                <Image url="@icons/game-icon.png"/>
                                            </image>
                                        </ImageView>
                                    </StackPane>
                                    <VBox spacing="3" HBox.hgrow="ALWAYS">
                                        <Label maxWidth="Infinity" text="Exit" styleClass="row-title"/>
                                        <Label maxWidth="Infinity" text="Close GameBox" styleClass="row-subtitle"/>
                                    </VBox>
                                    <StackPane styleClass="row-arrow-chip">
                                        <ImageView fitHeight="20.0" fitWidth="20.0" preserveRatio="true" styleClass="row-chevron-icon">
                                            <image>
                                                <Image url="@icons/icons8-chevron-right-96.png"/>
                                            </image>
                                        </ImageView>
                                    </StackPane>
                                </HBox>
                            </graphic>
                        </Button>
                    </VBox>
                </VBox>
            </StackPane>
        </StackPane>
    </ScrollPane>
</StackPane>
