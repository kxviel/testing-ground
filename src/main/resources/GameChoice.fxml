<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane fx:id="root"
           prefHeight="720.0"
           prefWidth="1080.0"
           focusTraversable="true"
           styleClass="game-choice-root"
           xmlns="http://javafx.com/javafx"
           xmlns:fx="http://javafx.com/fxml"
           fx:controller="seda_project.control_alt_defeat.gamebox.controller.GameChoice">

    <stylesheets>
        <URL value="@GameChoice.css"/>
    </stylesheets>

    <ScrollPane fitToHeight="true"
                fitToWidth="true"
                hbarPolicy="AS_NEEDED"
                vbarPolicy="AS_NEEDED"
                styleClass="app-scroll">
        <StackPane minHeight="680"
                   minWidth="960"
                   maxHeight="Infinity"
                   maxWidth="Infinity"
                   styleClass="game-choice-main">
            <StackPane prefHeight="640"
                       prefWidth="1080"
                       maxHeight="720"
                       maxWidth="1180"
                       styleClass="game-choice-frame">
                <VBox alignment="TOP_CENTER"
                      maxHeight="520"
                      maxWidth="640"
                      prefWidth="640"
                      spacing="26"
                      styleClass="game-choices">

                    <HBox alignment="CENTER" spacing="14" styleClass="title-divider">
                        <Region HBox.hgrow="ALWAYS" minWidth="80" styleClass="divider-line"/>
                        <Label text="Zero Runtime Warranty" styleClass="game-choice-title"/>
                        <Region HBox.hgrow="ALWAYS" minWidth="80" styleClass="divider-line"/>
                    </HBox>

                    <VBox spacing="18" styleClass="game-list">
                        <Button maxWidth="Infinity" onAction="#playMemory" styleClass="game-row">
                            <graphic>
                                <HBox alignment="CENTER_LEFT" maxWidth="Infinity" spacing="18" styleClass="row-content">
                                    <StackPane styleClass="icon-chip">
                                        <ImageView fitHeight="36.0" fitWidth="36.0" preserveRatio="true" styleClass="game-icon">
                                            <image>
                                                <Image url="@icons/icons8-memory-game-64.png"/>
                                            </image>
                                        </ImageView>
                                    </StackPane>

                                    <VBox spacing="4" HBox.hgrow="ALWAYS">
                                        <Label text="EarlyAlzheimers" styleClass="row-title"/>
                                        <Label text="Advanced Memory Game" styleClass="row-subtitle"/>
                                    </VBox>

                                    <StackPane styleClass="row-arrow-chip">
                                        <Label text="›" styleClass="row-arrow"/>
                                    </StackPane>
                                </HBox>
                            </graphic>
                        </Button>

                        <Button maxWidth="Infinity" onAction="#playTetris" styleClass="game-row">
                            <graphic>
                                <HBox alignment="CENTER_LEFT" maxWidth="Infinity" spacing="18" styleClass="row-content">
                                    <StackPane styleClass="icon-chip">
                                        <ImageView fitHeight="36.0" fitWidth="36.0" preserveRatio="true" styleClass="game-icon">
                                            <image>
                                                <Image url="@icons/icons8-tetris-64.png"/>
                                            </image>
                                        </ImageView>
                                    </StackPane>

                                    <VBox spacing="4" HBox.hgrow="ALWAYS">
                                        <Label text="Zetris" styleClass="row-title"/>
                                        <Label text="Advanced Tetris" styleClass="row-subtitle"/>
                                    </VBox>

                                    <StackPane styleClass="row-arrow-chip">
                                        <Label text="›" styleClass="row-arrow"/>
                                    </StackPane>
                                </HBox>
                            </graphic>
                        </Button>

                        <Button maxWidth="Infinity" onAction="#playHexChess" styleClass="game-row">
                            <graphic>
                                <HBox alignment="CENTER_LEFT" maxWidth="Infinity" spacing="18" styleClass="row-content">
                                    <StackPane styleClass="icon-chip">
                                        <ImageView fitHeight="38.0" fitWidth="38.0" preserveRatio="true" styleClass="game-icon">
                                            <image>
                                                <Image url="@icons/icons8-chess-100.png"/>
                                            </image>
                                        </ImageView>
                                    </StackPane>

                                    <VBox spacing="4" HBox.hgrow="ALWAYS">
                                        <Label text="Chessagon" styleClass="row-title"/>
                                        <Label text="Official Patent Hexagon Chess" styleClass="row-subtitle"/>
                                    </VBox>

                                    <StackPane styleClass="row-arrow-chip">
                                        <Label text="›" styleClass="row-arrow"/>
                                    </StackPane>
                                </HBox>
                            </graphic>
                        </Button>

                        <Button id="exit-row" maxWidth="Infinity" onAction="#exit" styleClass="game-row">
                            <graphic>
                                <HBox alignment="CENTER_LEFT" maxWidth="Infinity" spacing="18" styleClass="row-content">
                                    <StackPane styleClass="icon-chip">
                                        <Label text="X" styleClass="icon-letter"/>
                                    </StackPane>

                                    <VBox spacing="4" HBox.hgrow="ALWAYS">
                                        <Label text="Exit" styleClass="row-title"/>
                                        <Label text="Exit app" styleClass="row-subtitle"/>
                                    </VBox>

                                    <StackPane styleClass="row-arrow-chip">
                                        <Label text="›" styleClass="row-arrow"/>
                                    </StackPane>
                                </HBox>
                            </graphic>
                        </Button>
                    </VBox>
                </VBox>
            </StackPane>
        </StackPane>
    </ScrollPane>
</StackPane>
