<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane fx:id="root"
           prefHeight="720.0"
           prefWidth="1080.0"
           focusTraversable="true"
           styleClass="game-choice-root"
           xmlns="http://javafx.com/javafx"
           xmlns:fx="http://javafx.com/fxml"
           fx:controller="seda_project.control_alt_defeat.gamebox.controller.GameChoice">

    <stylesheets>
        <URL value="@GameChoice.css"/>
    </stylesheets>

    <ScrollPane fitToHeight="true"
                fitToWidth="true"
                hbarPolicy="AS_NEEDED"
                vbarPolicy="AS_NEEDED"
                styleClass="app-scroll">
        <StackPane minHeight="680"
                   minWidth="960"
                   maxHeight="Infinity"
                   maxWidth="Infinity"
                   alignment="TOP_CENTER"
                   styleClass="game-choice-main">
            <StackPane prefHeight="560"
                       prefWidth="1000"
                       maxHeight="600"
                       maxWidth="1080"
                       styleClass="game-choice-frame">
                <VBox alignment="TOP_CENTER"
                      prefHeight="470"
                      prefWidth="600"
                      maxHeight="500"
                      maxWidth="620"
                      spacing="28"
                      styleClass="game-choices">

                    <Label text="Zero Runtime Warranty" styleClass="game-choice-title"/>

                    <VBox spacing="24" styleClass="game-list">
                        <Button maxWidth="Infinity" onAction="#playMemory" styleClass="game-row">
                            <graphic>
                                <HBox alignment="CENTER_LEFT" maxWidth="Infinity" spacing="18" styleClass="row-content">
                                    <StackPane styleClass="icon-chip">
                                        <ImageView fitHeight="34.0" fitWidth="34.0" preserveRatio="true" styleClass="game-icon">
                                            <image>
                                                <Image url="@icons/icons8-memory-game-64.png"/>
                                            </image>
                                        </ImageView>
                                    </StackPane>
                                    <Label maxWidth="Infinity" text="EarlyAlzheimers" HBox.hgrow="ALWAYS" styleClass="row-title"/>
                                    <StackPane styleClass="row-arrow-chip">
                                        <ImageView fitHeight="20.0" fitWidth="20.0" preserveRatio="true" styleClass="row-chevron-icon">
                                            <image>
                                                <Image url="@icons/icons8-chevron-right-96.png"/>
                                            </image>
                                        </ImageView>
                                    </StackPane>
                                </HBox>
                            </graphic>
                        </Button>

                        <Button maxWidth="Infinity" onAction="#playTetris" styleClass="game-row">
                            <graphic>
                                <HBox alignment="CENTER_LEFT" maxWidth="Infinity" spacing="18" styleClass="row-content">
                                    <StackPane styleClass="icon-chip">
                                        <ImageView fitHeight="34.0" fitWidth="34.0" preserveRatio="true" styleClass="game-icon">
                                            <image>
                                                <Image url="@icons/icons8-tetris-64.png"/>
                                            </image>
                                        </ImageView>
                                    </StackPane>
                                    <Label maxWidth="Infinity" text="Zetris" HBox.hgrow="ALWAYS" styleClass="row-title"/>
                                    <StackPane styleClass="row-arrow-chip">
                                        <ImageView fitHeight="20.0" fitWidth="20.0" preserveRatio="true" styleClass="row-chevron-icon">
                                            <image>
                                                <Image url="@icons/icons8-chevron-right-96.png"/>
                                            </image>
                                        </ImageView>
                                    </StackPane>
                                </HBox>
                            </graphic>
                        </Button>

                        <Button maxWidth="Infinity" onAction="#playHexChess" styleClass="game-row">
                            <graphic>
                                <HBox alignment="CENTER_LEFT" maxWidth="Infinity" spacing="18" styleClass="row-content">
                                    <StackPane styleClass="icon-chip">
                                        <ImageView fitHeight="36.0" fitWidth="36.0" preserveRatio="true" styleClass="game-icon">
                                            <image>
                                                <Image url="@icons/icons8-chess-100.png"/>
                                            </image>
                                        </ImageView>
                                    </StackPane>
                                    <Label maxWidth="Infinity" text="Chexsagon" HBox.hgrow="ALWAYS" styleClass="row-title"/>
                                    <StackPane styleClass="row-arrow-chip">
                                        <ImageView fitHeight="20.0" fitWidth="20.0" preserveRatio="true" styleClass="row-chevron-icon">
                                            <image>
                                                <Image url="@icons/icons8-chevron-right-96.png"/>
                                            </image>
                                        </ImageView>
                                    </StackPane>
                                </HBox>
                            </graphic>
                        </Button>

                        <Button id="exit-row" maxWidth="Infinity" onAction="#exit" styleClass="game-row">
                            <graphic>
                                <HBox alignment="CENTER_LEFT" maxWidth="Infinity" spacing="18" styleClass="row-content">
                                    <StackPane styleClass="icon-chip">
                                        <Label text="X" styleClass="icon-letter"/>
                                    </StackPane>
                                    <Label maxWidth="Infinity" text="Exit" HBox.hgrow="ALWAYS" styleClass="row-title"/>
                                    <StackPane styleClass="row-arrow-chip">
                                        <ImageView fitHeight="20.0" fitWidth="20.0" preserveRatio="true" styleClass="row-chevron-icon">
                                            <image>
                                                <Image url="@icons/icons8-chevron-right-96.png"/>
                                            </image>
                                        </ImageView>
                                    </StackPane>
                                </HBox>
                            </graphic>
                        </Button>
                    </VBox>
                </VBox>
            </StackPane>
        </StackPane>
    </ScrollPane>
</StackPane>
